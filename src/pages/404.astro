---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada">
  <div class="max-w-lg mx-auto px-4 py-24 text-center">
    <p class="text-6xl font-bold text-brand-600 mb-4">404</p>
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">Página no encontrada</h1>
    <p class="text-gray-500 mb-8">La dirección que buscas no existe o fue eliminada.</p>
    <a
      href="/"
      class="inline-block bg-brand-600 text-white px-6 py-2.5 rounded font-medium hover:bg-brand-700 transition-colors"
    >
      Ver ofertas de empleo
    </a>
  </div>
</Layout>
