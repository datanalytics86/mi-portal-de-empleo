---
import Layout from '../layouts/Layout.astro';
import FiltrosBusqueda from '../components/FiltrosBusqueda.astro';
import MapaOfertas from '../components/MapaOfertas.astro';
import OfertaCard from '../components/OfertaCard.astro';
import { ofertas } from '../lib/ofertas';
---

<Layout title="Mi portal de empleo">
  <section class="grid gap-10">
    <div class="space-y-4 rounded-3xl border border-border/60 bg-white/95 p-8 shadow-[0_20px_45px_rgba(15,23,42,0.08)]">
      <div class="inline-flex items-center gap-2 rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold text-accent">
        Sin registros · Postulación express
      </div>
      <h2 class="text-3xl font-semibold text-text-primary md:text-4xl">Encuentra tu próxima oportunidad sin fricción</h2>
      <p class="max-w-2xl text-text-secondary">
        Explora ofertas activas en el mapa. Postula sin registrarte: solo sube tu CV y listo.
      </p>
      <div class="flex flex-wrap gap-3 text-sm text-text-secondary">
        <span class="pill">+100 ofertas activas</span>
        <span class="pill">Respuesta rápida</span>
        <span class="pill">Privacidad primero</span>
      </div>
    </div>

    <FiltrosBusqueda />

    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <MapaOfertas ofertas={ofertas} />
      <div class="grid gap-4" data-list>
        {ofertas.map((oferta) => (
          <OfertaCard oferta={oferta} />
        ))}
        <div data-empty class="hidden rounded-2xl border border-dashed border-border bg-surface p-6 text-sm text-text-secondary">
          No encontramos ofertas con esos filtros. Prueba con otra búsqueda.
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ ofertas }}>
  const searchInput = document.querySelector('[data-filter="search"]');
  const jornadaSelect = document.querySelector('[data-filter="jornada"]');
  const comunaSelect = document.querySelector('[data-filter="comuna"]');
  const cards = Array.from(document.querySelectorAll('[data-oferta]'));
  const emptyState = document.querySelector('[data-empty]');

  const normalize = (value) =>
    value
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .trim();

  const applyFilters = () => {
    const searchValue = normalize(searchInput?.value ?? '');
    const jornadaValue = normalize(jornadaSelect?.value ?? 'todos');
    const comunaValue = normalize(comunaSelect?.value ?? 'todas');
    const matchedIds = [];

    cards.forEach((card) => {
      const titulo = normalize(card.dataset.titulo ?? '');
      const empresa = normalize(card.dataset.empresa ?? '');
      const jornada = normalize(card.dataset.jornada ?? '');
      const comuna = normalize(card.dataset.comuna ?? '');

      const matchesSearch = !searchValue || titulo.includes(searchValue) || empresa.includes(searchValue);
      const matchesJornada = jornadaValue === 'todos' || jornada === jornadaValue;
      const matchesComuna = comunaValue === 'todas' || comuna === comunaValue;
      const isVisible = matchesSearch && matchesJornada && matchesComuna;

      card.hidden = !isVisible;
      if (isVisible && card.dataset.id) {
        matchedIds.push(card.dataset.id);
      }
    });

    if (emptyState) {
      emptyState.hidden = matchedIds.length !== 0;
    }

    document.dispatchEvent(new CustomEvent('ofertas:filter', { detail: { ids: matchedIds } }));
  };

  [searchInput, jornadaSelect, comunaSelect].forEach((element) => {
    if (!element) return;
    element.addEventListener('input', applyFilters);
    element.addEventListener('change', applyFilters);
  });

  applyFilters();
</script>
