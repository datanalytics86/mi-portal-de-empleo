---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import { TIPOS, CATEGORIAS, CATEGORIA_COLORS } from '../lib/constants';

// Filtros desde URL
const { searchParams } = Astro.url;
const q = searchParams.get('q') || '';
const tipo = searchParams.get('tipo') || '';
const comuna = searchParams.get('comuna') || '';
const categoria = searchParams.get('categoria') || '';

// Obtener ofertas activas
let query = supabase
  .from('ofertas')
  .select('id, titulo, empresa, tipo_empleo, categoria, comuna, created_at, expira_en, lat, lng')
  .eq('activa', true)
  .gte('expira_en', new Date().toISOString())
  .order('created_at', { ascending: false });

if (q) query = query.ilike('titulo', `%${q}%`);
if (tipo) query = query.eq('tipo_empleo', tipo);
if (comuna) query = query.ilike('comuna', `%${comuna}%`);
if (categoria) query = query.eq('categoria', categoria);

const { data: ofertas = [] } = await query.limit(60);

// Serializar datos para el mapa
const mapaOfertas = (ofertas || []).map(o => ({
  id: o.id, titulo: o.titulo, empresa: o.empresa,
  lat: o.lat, lng: o.lng, comuna: o.comuna, categoria: o.categoria ?? '',
}));

const hayFiltros = q || tipo || comuna || categoria;

// Construye URL de categoría preservando otros filtros
function buildCatUrl(cat: string | null) {
  const p = new URLSearchParams();
  if (cat) p.set('categoria', cat);
  if (q) p.set('q', q);
  if (tipo) p.set('tipo', tipo);
  if (comuna) p.set('comuna', comuna);
  const qs = p.toString();
  return qs ? `/?${qs}` : '/';
}
---

<Layout title="Empleos en Chile" leaflet={true}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-700 via-brand-600 to-indigo-700 py-14 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-3 tracking-tight leading-tight">
        Encuentra tu próximo<br class="hidden sm:block" />
        <span class="bg-gradient-to-r from-white to-indigo-200 bg-clip-text text-transparent">empleo en Chile</span>
      </h1>
      <p class="text-brand-100 text-lg mb-8">
        <span id="hero-count" data-target={ofertas?.length ?? 0}>0</span>
        {' '}oportunidad{(ofertas?.length ?? 0) !== 1 ? 'es' : ''} activa{(ofertas?.length ?? 0) !== 1 ? 's' : ''} en todo el país
      </p>

      <!-- Barra de búsqueda integrada -->
      <form method="get" class="bg-white rounded-2xl shadow-2xl p-2 flex flex-col sm:flex-row gap-2 max-w-3xl mx-auto">
        <input type="hidden" name="categoria" value={categoria} />
        <div class="flex-1 flex items-center gap-2 px-3">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            name="q"
            value={q}
            placeholder="Cargo, empresa... (pulsa /)"
            class="flex-1 py-2.5 text-gray-900 placeholder-gray-400 focus:outline-none text-sm bg-transparent"
          />
        </div>
        <div class="hidden sm:block w-px bg-gray-200 my-1.5"></div>
        <select
          name="tipo"
          class="px-3 py-2.5 text-gray-600 focus:outline-none bg-transparent text-sm rounded-lg cursor-pointer"
        >
          <option value="">Tipo de empleo</option>
          {Object.entries(TIPOS).map(([val, label]) => (
            <option value={val} selected={tipo === val}>{label}</option>
          ))}
        </select>
        <div class="hidden sm:block w-px bg-gray-200 my-1.5"></div>
        <div class="flex items-center gap-2 px-3 sm:w-36">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <input
            type="text"
            name="comuna"
            value={comuna}
            placeholder="Comuna..."
            class="flex-1 py-2.5 text-gray-900 placeholder-gray-400 focus:outline-none text-sm bg-transparent"
          />
        </div>
        <button
          type="submit"
          class="bg-brand-600 text-white px-6 py-2.5 rounded-xl text-sm font-semibold hover:bg-brand-700 transition-colors shrink-0"
        >
          Buscar
        </button>
      </form>

      <!-- Pills de categoría -->
      <div class="flex flex-wrap justify-center gap-2 mt-4">
        <a
          href={buildCatUrl(null)}
          class={`px-3 py-1 rounded-full text-xs font-medium transition-colors border ${!categoria ? 'bg-white text-brand-700 border-white shadow-sm' : 'bg-white/15 text-white border-white/25 hover:bg-white/25'}`}
        >
          Todas
        </a>
        {CATEGORIAS.map(cat => (
          <a
            href={buildCatUrl(cat)}
            class={`px-3 py-1 rounded-full text-xs font-medium transition-colors border ${categoria === cat ? 'bg-white text-brand-700 border-white shadow-sm' : 'bg-white/15 text-white border-white/25 hover:bg-white/25'}`}
          >
            {cat}
          </a>
        ))}
      </div>

      {hayFiltros && (
        <a href="/" class="mt-3 inline-block text-brand-200 hover:text-white text-sm underline transition-colors">
          Limpiar filtros
        </a>
      )}
    </div>
  </section>

  <!-- Sección dual: postulantes / empleadores -->
  {!hayFiltros && (
    <section class="bg-white border-b border-gray-100 py-6 px-4">
      <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-4 p-5 rounded-xl bg-brand-50 border border-brand-100 hover:border-brand-300 transition-colors">
          <div class="p-3 bg-brand-100 rounded-xl text-brand-700 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900">¿Eres postulante?</h3>
            <p class="text-sm text-gray-600 mt-1">Explora empleos, filtra por ubicación y postula con tu CV en segundos.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-5 rounded-xl bg-indigo-50 border border-indigo-100 hover:border-indigo-300 transition-colors">
          <div class="p-3 bg-indigo-100 rounded-xl text-indigo-700 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900">¿Eres empleador?</h3>
            <p class="text-sm text-gray-600 mt-1">Publica ofertas gratis, recibe CVs y gestiona tus postulaciones fácilmente.</p>
            <a href="/empleador/login" class="mt-2 inline-block text-sm font-semibold text-indigo-700 hover:text-indigo-900 transition-colors">
              Publicar empleo →
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <div class="max-w-6xl mx-auto px-4 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Mapa -->
      <div class="lg:sticky lg:top-20 h-[420px] rounded-xl overflow-hidden border border-gray-200 shadow-md">
        <div id="mapa" class="w-full h-full"></div>
      </div>

      <!-- Listado -->
      <div>
        <p class="text-sm text-gray-500 mb-4 font-medium">
          <span class="text-gray-900 font-semibold">{ofertas?.length ?? 0}</span> oferta{(ofertas?.length ?? 0) !== 1 ? 's' : ''} encontrada{(ofertas?.length ?? 0) !== 1 ? 's' : ''}
          {hayFiltros && <span class="ml-1 text-brand-600">(filtrado)</span>}
        </p>

        {!ofertas || ofertas.length === 0 ? (
          <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <p class="text-gray-700 font-semibold">No hay ofertas disponibles</p>
            <p class="text-sm text-gray-400 mt-1">Intenta con otros filtros o amplía la búsqueda</p>
            {hayFiltros && (
              <a href="/" class="mt-4 inline-block bg-brand-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-brand-700 transition-colors">
                Ver todas las ofertas
              </a>
            )}
          </div>
        ) : (
          <div class="space-y-3">
            {ofertas.map((oferta, i) => {
              const esNueva = (Date.now() - new Date(oferta.created_at).getTime()) < 48 * 3600 * 1000;
              const diasRestantes = Math.ceil((new Date(oferta.expira_en).getTime() - Date.now()) / (1000 * 60 * 60 * 24));
              const iniciales = oferta.empresa
                .split(' ')
                .slice(0, 2)
                .map((w: string) => w[0] || '')
                .join('')
                .toUpperCase()
                .slice(0, 2);
              const catColor = oferta.categoria
                ? (CATEGORIA_COLORS[oferta.categoria] || 'bg-gray-100 text-gray-600 border-gray-200')
                : '';
              // Pre-computadas para evitar template literals anidados en expresiones Astro
              const animDelay = 'animation-delay: ' + (i * 55) + 'ms';
              const urgenciaLabel = diasRestantes <= 1 ? 'Último día' : ('Cierra en ' + diasRestantes + 'd');
              const urgenciaClass = 'text-xs px-2 py-0.5 rounded-full font-medium shrink-0 ' + (diasRestantes <= 1 ? 'bg-red-100 text-red-700' : diasRestantes <= 3 ? 'bg-orange-100 text-orange-700' : 'bg-yellow-100 text-yellow-700');
              return (
                <a
                  href={`/oferta/${oferta.id}`}
                  class="card-anim flex gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-brand-400 hover:shadow-md transition-all group"
                  style={animDelay}
                >
                  <!-- Avatar empresa -->
                  <div class="w-10 h-10 rounded-lg bg-brand-50 border border-brand-100 flex items-center justify-center shrink-0 text-brand-700 font-bold text-sm group-hover:bg-brand-100 transition-colors">
                    {iniciales}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-2">
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                          <h2 class="font-semibold text-gray-900 truncate group-hover:text-brand-700 transition-colors">{oferta.titulo}</h2>
                          {esNueva && (
                            <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium shrink-0">Nueva</span>
                          )}
                          {diasRestantes <= 5 && (
                            <span class={urgenciaClass}>
                              {urgenciaLabel}
                            </span>
                          )}
                        </div>
                        <p class="text-sm text-gray-500 mt-0.5">{oferta.empresa}</p>
                      </div>
                      <span class="text-xs text-gray-400 whitespace-nowrap shrink-0 mt-0.5">
                        {new Date(oferta.created_at).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' })}
                      </span>
                    </div>
                    <div class="flex flex-wrap gap-1.5 mt-2">
                      <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full flex items-center gap-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        </svg>
                        {oferta.comuna}
                      </span>
                      <span class="text-xs bg-brand-50 text-brand-700 px-2 py-0.5 rounded-full font-medium">
                        {TIPOS[oferta.tipo_empleo] || oferta.tipo_empleo}
                      </span>
                      {oferta.categoria && (
                        <span class={`text-xs border px-2 py-0.5 rounded-full font-medium ${catColor}`}>
                          {oferta.categoria}
                        </span>
                      )}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ mapaOfertas }}>
  document.addEventListener('DOMContentLoaded', () => {
    const map = L.map('mapa').setView([-33.4569, -70.6483], 11);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 18,
    }).addTo(map);

    function esc(s) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    const CAT_COLORS = {
      'Tecnología': '#4f46e5', 'Administración': '#0ea5e9', 'Salud': '#10b981',
      'Educación': '#f59e0b', 'Ventas': '#ef4444', 'Construcción': '#f97316',
      'Logística': '#8b5cf6', 'Gastronomía': '#ec4899', 'Finanzas': '#14b8a6',
      'Legal': '#6366f1', 'Marketing': '#d946ef', 'RRHH': '#64748b',
    };

    mapaOfertas.forEach((oferta) => {
      if (!oferta.lat || !oferta.lng) return;
      const color = CAT_COLORS[oferta.categoria] || '#4f46e5';
      const icon = L.divIcon({
        html: `<div style="width:14px;height:14px;background:${color};border-radius:50%;border:2.5px solid white;box-shadow:0 1px 4px rgba(0,0,0,0.4)"></div>`,
        className: '',
        iconSize: [14, 14],
        iconAnchor: [7, 7],
      });
      const marker = L.marker([oferta.lat, oferta.lng], { icon });
      marker.bindPopup(`
        <div style="min-width:160px">
          <strong>${esc(oferta.titulo)}</strong><br>
          <span style="color:#555">${esc(oferta.empresa)}</span><br>
          <span style="color:#888;font-size:12px">${esc(oferta.comuna)}</span><br>
          <a href="/oferta/${encodeURIComponent(oferta.id)}" style="color:#2563eb;font-size:13px">Ver oferta →</a>
        </div>
      `);
      marker.addTo(map);
    });
  });
</script>

<script>
  // Animated counter: cuenta desde 0 hasta el target en ~700ms
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target || '0', 10);
    if (target === 0) { el.textContent = '0'; return; }
    const duration = 700;
    const start = performance.now();
    const step = (now: number) => {
      const elapsed = Math.min((now - start) / duration, 1);
      // easeOutCubic
      const eased = 1 - Math.pow(1 - elapsed, 3);
      el.textContent = String(Math.round(eased * target));
      if (elapsed < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  document.addEventListener('astro:page-load', () => {
    const el = document.getElementById('hero-count');
    if (el) animateCounter(el);
  });
</script>

<style>
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .card-anim {
    animation: fadeSlideUp 0.38s ease both;
  }
</style>
