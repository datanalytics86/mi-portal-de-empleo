---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import { TIPOS, CATEGORIAS, CATEGORIA_COLORS } from '../lib/constants';

// Filtros desde URL
const { searchParams } = Astro.url;
const q = searchParams.get('q') || '';
const tipo = searchParams.get('tipo') || '';
const comuna = searchParams.get('comuna') || '';
const categoria = searchParams.get('categoria') || '';

// Obtener ofertas activas
let query = supabase
  .from('ofertas')
  .select('id, titulo, empresa, tipo_empleo, categoria, comuna, created_at, expira_en, lat, lng')
  .eq('activa', true)
  .gte('expira_en', new Date().toISOString())
  .order('created_at', { ascending: false });

if (q) query = query.ilike('titulo', `%${q}%`);
if (tipo) query = query.eq('tipo_empleo', tipo);
if (comuna) query = query.ilike('comuna', `%${comuna}%`);
if (categoria) query = query.eq('categoria', categoria);

const { data: ofertas = [] } = await query.limit(60);

// Serializar datos para el mapa
const mapaOfertas = (ofertas || []).map(o => ({
  id: o.id, titulo: o.titulo, empresa: o.empresa,
  lat: o.lat, lng: o.lng, comuna: o.comuna, categoria: o.categoria ?? '',
}));

const hayFiltros = q || tipo || comuna || categoria;

// Construye URL de categoría preservando otros filtros
function buildCatUrl(cat: string | null) {
  const p = new URLSearchParams();
  if (cat) p.set('categoria', cat);
  if (q) p.set('q', q);
  if (tipo) p.set('tipo', tipo);
  if (comuna) p.set('comuna', comuna);
  const qs = p.toString();
  return qs ? `/?${qs}` : '/';
}
---

<Layout title="Empleos en Chile" leaflet={true}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-800 via-brand-600 to-indigo-600 py-16 sm:py-20 px-4">
    <!-- Decoración suave -->
    <div class="pointer-events-none absolute inset-0 bg-hero-mesh opacity-90" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -top-24 -right-24 w-72 h-72 rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -bottom-32 -left-16 w-80 h-80 rounded-full bg-brand-400/20 blur-3xl" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/90 text-xs font-medium px-3 py-1.5 rounded-full mb-5 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-300 animate-pulse"></span>
        Postula sin registro · CV en segundos
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-[3.25rem] font-extrabold text-white mb-4 tracking-tight leading-[1.1]">
        Encuentra tu próximo<br class="hidden sm:block" />
        <span class="bg-gradient-to-r from-white via-brand-100 to-indigo-200 bg-clip-text text-transparent">
          empleo en Chile
        </span>
      </h1>
      <p class="text-brand-100/95 text-base sm:text-lg mb-8 max-w-xl mx-auto leading-relaxed">
        <span id="hero-count" class="font-bold text-white tabular-nums" data-target={ofertas?.length ?? 0}>0</span>
        {' '}oportunidad{(ofertas?.length ?? 0) !== 1 ? 'es' : ''} activa{(ofertas?.length ?? 0) !== 1 ? 's' : ''}
        · mapa interactivo · keywords automáticas del CV
      </p>

      <!-- Barra de búsqueda -->
      <form
        method="get"
        class="bg-white/95 backdrop-blur rounded-2xl shadow-glow p-2 sm:p-2.5 flex flex-col sm:flex-row gap-1.5 sm:gap-0 max-w-3xl mx-auto ring-1 ring-white/40"
      >
        <input type="hidden" name="categoria" value={categoria} />
        <div class="flex-1 flex items-center gap-2 px-3 min-w-0">
          <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            name="q"
            value={q}
            placeholder="Cargo, empresa… (tecla /)"
            class="flex-1 py-2.5 text-slate-900 placeholder-slate-400 focus:outline-none text-sm bg-transparent min-w-0"
          />
        </div>
        <div class="hidden sm:block w-px bg-slate-200 my-2"></div>
        <select
          name="tipo"
          class="px-3 py-2.5 text-slate-600 focus:outline-none bg-transparent text-sm rounded-lg cursor-pointer"
        >
          <option value="">Tipo de empleo</option>
          {Object.entries(TIPOS).map(([val, label]) => (
            <option value={val} selected={tipo === val}>{label}</option>
          ))}
        </select>
        <div class="hidden sm:block w-px bg-slate-200 my-2"></div>
        <div class="flex items-center gap-2 px-3 sm:w-36">
          <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <input
            type="text"
            name="comuna"
            value={comuna}
            placeholder="Comuna…"
            class="flex-1 py-2.5 text-slate-900 placeholder-slate-400 focus:outline-none text-sm bg-transparent min-w-0"
          />
        </div>
        <button
          type="submit"
          class="bg-gradient-to-r from-brand-600 to-brand-700 text-white px-6 py-2.5 rounded-xl text-sm font-semibold hover:from-brand-700 hover:to-brand-800 transition-all shrink-0 shadow-soft"
        >
          Buscar
        </button>
      </form>

      <!-- Trust row -->
      <div class="flex flex-wrap justify-center gap-x-5 gap-y-2 mt-5 text-[11px] sm:text-xs text-white/75 font-medium">
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Sin cuenta
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          CV privado 90 días
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Mapa por comuna
        </span>
      </div>

      <!-- Pills de categoría -->
      <div class="flex flex-wrap justify-center gap-2 mt-6">
        <a
          href={buildCatUrl(null)}
          class={`px-3.5 py-1.5 rounded-full text-xs font-semibold transition-all border ${!categoria ? 'bg-white text-brand-700 border-white shadow-soft' : 'bg-white/10 text-white border-white/20 hover:bg-white/20'}`}
        >
          Todas
        </a>
        {CATEGORIAS.map(cat => (
          <a
            href={buildCatUrl(cat)}
            class={`px-3.5 py-1.5 rounded-full text-xs font-medium transition-all border ${categoria === cat ? 'bg-white text-brand-700 border-white shadow-soft' : 'bg-white/10 text-white/95 border-white/20 hover:bg-white/20'}`}
          >
            {cat}
          </a>
        ))}
      </div>

      {hayFiltros && (
        <a href="/" class="mt-4 inline-flex items-center gap-1 text-brand-100 hover:text-white text-sm font-medium transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          Limpiar filtros
        </a>
      )}
    </div>
  </section>

  <!-- Dual CTA -->
  {!hayFiltros && (
    <section class="bg-white/70 border-b border-slate-100 py-7 px-4">
      <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="group flex items-start gap-4 p-5 rounded-2xl bg-gradient-to-br from-brand-50 to-white border border-brand-100/80 shadow-soft hover:shadow-card hover:border-brand-200 transition-all">
          <div class="p-3 bg-white rounded-xl text-brand-600 shrink-0 shadow-soft border border-brand-100 group-hover:scale-105 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-slate-900 tracking-tight">¿Buscas trabajo?</h3>
            <p class="text-sm text-slate-600 mt-1 leading-relaxed">Explora el mapa, filtra por comuna y postula solo con tu CV.</p>
            <p class="mt-2 text-xs font-semibold text-brand-600">Desplázate y elige una oferta ↓</p>
          </div>
        </div>
        <a
          href="/empleador/login"
          class="group flex items-start gap-4 p-5 rounded-2xl bg-gradient-to-br from-indigo-50 to-white border border-indigo-100/80 shadow-soft hover:shadow-card hover:border-indigo-200 transition-all"
        >
          <div class="p-3 bg-white rounded-xl text-indigo-600 shrink-0 shadow-soft border border-indigo-100 group-hover:scale-105 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-slate-900 tracking-tight">¿Contratar?</h3>
            <p class="text-sm text-slate-600 mt-1 leading-relaxed">Publica gratis, recibe CVs y ve keywords automáticas.</p>
            <span class="mt-2 inline-flex items-center gap-1 text-sm font-semibold text-indigo-700 group-hover:gap-2 transition-all">
              Publicar empleo
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </a>
      </div>
    </section>
  )}

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
      <!-- Mapa -->
      <div class="lg:sticky lg:top-24 h-[420px] rounded-2xl overflow-hidden border border-slate-200/80 shadow-card ring-1 ring-slate-900/5">
        <div id="mapa" class="w-full h-full"></div>
      </div>

      <!-- Listado -->
      <div>
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm text-slate-500 font-medium">
            <span class="text-slate-900 font-bold tabular-nums">{ofertas?.length ?? 0}</span>
            {' '}oferta{(ofertas?.length ?? 0) !== 1 ? 's' : ''}
            {hayFiltros && <span class="ml-1.5 text-brand-600 font-semibold">· filtrado</span>}
          </p>
        </div>

        {!ofertas || ofertas.length === 0 ? (
          <div class="text-center py-16 bg-white rounded-2xl border border-slate-200 shadow-soft">
            <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-slate-100">
              <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <p class="text-slate-800 font-semibold">No hay ofertas con esos filtros</p>
            <p class="text-sm text-slate-400 mt-1">Prueba otra comuna o limpia la búsqueda</p>
            {hayFiltros && (
              <a href="/" class="mt-5 inline-block bg-brand-600 text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:bg-brand-700 transition-colors shadow-soft">
                Ver todas las ofertas
              </a>
            )}
          </div>
        ) : (
          <div class="space-y-3">
            {ofertas.map((oferta, i) => {
              const esNueva = (Date.now() - new Date(oferta.created_at).getTime()) < 48 * 3600 * 1000;
              const diasRestantes = Math.ceil((new Date(oferta.expira_en).getTime() - Date.now()) / (1000 * 60 * 60 * 24));
              const iniciales = oferta.empresa
                .split(' ')
                .slice(0, 2)
                .map((w: string) => w[0] || '')
                .join('')
                .toUpperCase()
                .slice(0, 2);
              const catColor = oferta.categoria
                ? (CATEGORIA_COLORS[oferta.categoria] || 'bg-slate-100 text-slate-600 border-slate-200')
                : '';
              const animDelay = 'animation-delay: ' + (i * 50) + 'ms';
              const urgenciaLabel = diasRestantes <= 1 ? 'Último día' : ('Cierra en ' + diasRestantes + 'd');
              const urgenciaClass = 'text-[11px] px-2 py-0.5 rounded-full font-semibold shrink-0 ' + (diasRestantes <= 1 ? 'bg-red-50 text-red-700 border border-red-100' : diasRestantes <= 3 ? 'bg-orange-50 text-orange-700 border border-orange-100' : 'bg-amber-50 text-amber-700 border border-amber-100');
              return (
                <a
                  href={`/oferta/${oferta.id}`}
                  class="card-anim flex gap-3.5 bg-white border border-slate-200/90 rounded-2xl p-4 shadow-soft hover:border-brand-300 hover:shadow-card-hover hover:-translate-y-0.5 transition-all group"
                  style={animDelay}
                >
                  <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-50 to-brand-100 border border-brand-100/80 flex items-center justify-center shrink-0 text-brand-700 font-bold text-sm group-hover:from-brand-100 group-hover:to-brand-200 transition-colors">
                    {iniciales}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-2">
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                          <h2 class="font-semibold text-slate-900 truncate group-hover:text-brand-700 transition-colors tracking-tight">
                            {oferta.titulo}
                          </h2>
                          {esNueva && (
                            <span class="text-[11px] bg-emerald-50 text-emerald-700 border border-emerald-100 px-2 py-0.5 rounded-full font-semibold shrink-0">
                              Nueva
                            </span>
                          )}
                          {diasRestantes <= 5 && (
                            <span class={urgenciaClass}>{urgenciaLabel}</span>
                          )}
                        </div>
                        <p class="text-sm text-slate-500 mt-0.5 font-medium">{oferta.empresa}</p>
                      </div>
                      <span class="text-[11px] text-slate-400 whitespace-nowrap shrink-0 mt-0.5 font-medium tabular-nums">
                        {new Date(oferta.created_at).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' })}
                      </span>
                    </div>
                    <div class="flex flex-wrap gap-1.5 mt-2.5">
                      <span class="text-[11px] bg-slate-50 text-slate-600 border border-slate-100 px-2 py-0.5 rounded-full flex items-center gap-1 font-medium">
                        <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        </svg>
                        {oferta.comuna}
                      </span>
                      <span class="text-[11px] bg-brand-50 text-brand-700 border border-brand-100 px-2 py-0.5 rounded-full font-semibold">
                        {TIPOS[oferta.tipo_empleo] || oferta.tipo_empleo}
                      </span>
                      {oferta.categoria && (
                        <span class={`text-[11px] border px-2 py-0.5 rounded-full font-medium ${catColor}`}>
                          {oferta.categoria}
                        </span>
                      )}
                    </div>
                  </div>
                  <div class="hidden sm:flex items-center text-slate-300 group-hover:text-brand-500 transition-colors self-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ mapaOfertas }}>
  document.addEventListener('DOMContentLoaded', () => {
    const map = L.map('mapa').setView([-33.4569, -70.6483], 11);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 18,
    }).addTo(map);

    function esc(s) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    const CAT_COLORS = {
      'Tecnología': '#4f46e5', 'Administración': '#0ea5e9', 'Salud': '#10b981',
      'Educación': '#f59e0b', 'Ventas': '#ef4444', 'Construcción': '#f97316',
      'Logística': '#8b5cf6', 'Gastronomía': '#ec4899', 'Finanzas': '#14b8a6',
      'Legal': '#6366f1', 'Marketing': '#d946ef', 'RRHH': '#64748b',
    };

    mapaOfertas.forEach((oferta) => {
      if (!oferta.lat || !oferta.lng) return;
      const color = CAT_COLORS[oferta.categoria] || '#4f46e5';
      const icon = L.divIcon({
        html: `<div style="width:14px;height:14px;background:${color};border-radius:50%;border:2.5px solid white;box-shadow:0 1px 4px rgba(0,0,0,0.4)"></div>`,
        className: '',
        iconSize: [14, 14],
        iconAnchor: [7, 7],
      });
      const marker = L.marker([oferta.lat, oferta.lng], { icon });
      marker.bindPopup(`
        <div style="min-width:160px">
          <strong>${esc(oferta.titulo)}</strong><br>
          <span style="color:#555">${esc(oferta.empresa)}</span><br>
          <span style="color:#888;font-size:12px">${esc(oferta.comuna)}</span><br>
          <a href="/oferta/${encodeURIComponent(oferta.id)}" style="color:#2563eb;font-size:13px">Ver oferta →</a>
        </div>
      `);
      marker.addTo(map);
    });
  });
</script>

<script>
  // Animated counter: cuenta desde 0 hasta el target en ~700ms
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target || '0', 10);
    if (target === 0) { el.textContent = '0'; return; }
    const duration = 700;
    const start = performance.now();
    const step = (now: number) => {
      const elapsed = Math.min((now - start) / duration, 1);
      // easeOutCubic
      const eased = 1 - Math.pow(1 - elapsed, 3);
      el.textContent = String(Math.round(eased * target));
      if (elapsed < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  document.addEventListener('astro:page-load', () => {
    const el = document.getElementById('hero-count');
    if (el) animateCounter(el);
  });
</script>

<style>
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .card-anim {
    animation: fadeSlideUp 0.38s ease both;
  }
</style>
