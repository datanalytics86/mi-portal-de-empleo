---
import Layout from '../../layouts/Layout.astro';
import { getEmpleadorSession } from '../../lib/auth';

// Si ya está logueado, redirigir al dashboard
const session = await getEmpleadorSession(Astro.cookies);
if (session) return Astro.redirect('/empleador/dashboard');

const error = Astro.url.searchParams.get('error');
---

<Layout title="Acceso empleadores">
  <div class="max-w-md mx-auto px-4 py-16">
    <div class="bg-white border border-gray-200 rounded-lg p-8">
      <h1 class="text-xl font-bold text-gray-900 mb-1">Acceso para empleadores</h1>
      <p class="text-sm text-gray-500 mb-6">
        ¿No tienes cuenta?
        <a href="/empleador/registro" class="text-brand-600 hover:underline">Regístrate gratis</a>
      </p>

      {error && (
        <div class="mb-4 bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
          {error === 'credenciales' ? 'Email o contraseña incorrectos.' : 'Error al iniciar sesión. Intenta de nuevo.'}
        </div>
      )}

      <form id="form-login" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
          <input
            type="password"
            name="password"
            required
            autocomplete="current-password"
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>

        <div id="login-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded p-2"></div>

        <button
          type="submit"
          id="btn-login"
          class="w-full bg-brand-600 text-white py-2.5 rounded font-medium hover:bg-brand-700 transition-colors disabled:opacity-60"
        >
          Ingresar
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('form-login') as HTMLFormElement;
  const btn = document.getElementById('btn-login') as HTMLButtonElement;
  const errEl = document.getElementById('login-error') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Ingresando...';
    btn.disabled = true;
    errEl.classList.add('hidden');

    const body = new FormData(form);
    const res = await fetch('/api/auth/login', { method: 'POST', body });
    const data = await res.json();

    if (res.ok && data.ok) {
      window.location.href = '/empleador/dashboard';
    } else {
      errEl.textContent = data.error || 'Error al iniciar sesión.';
      errEl.classList.remove('hidden');
      btn.textContent = 'Ingresar';
      btn.disabled = false;
    }
  });
</script>
