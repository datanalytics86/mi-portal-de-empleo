---
import Layout from '../../layouts/Layout.astro';
import { getEmpleadorSession } from '../../lib/auth';

// Si ya está logueado, redirigir al dashboard
const session = await getEmpleadorSession(Astro.cookies);
if (session) return Astro.redirect('/empleador/dashboard');

const error = Astro.url.searchParams.get('error');
---

<Layout title="Acceso empleadores">
  <div class="min-h-[calc(100vh-140px)] flex items-center justify-center px-4 py-12 bg-gray-50">
    <div class="w-full max-w-md">
      <!-- Logo / branding -->
      <div class="text-center mb-8 form-enter" style="animation-delay:0ms">
        <div class="w-14 h-14 bg-brand-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h1 class="text-2xl font-extrabold text-gray-900">Bienvenido de vuelta</h1>
        <p class="text-gray-500 mt-1 text-sm">
          ¿No tienes cuenta?{' '}
          <a href="/empleador/registro" class="text-brand-600 hover:text-brand-700 font-semibold">Regístrate gratis</a>
        </p>
      </div>

      <div class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm form-enter" style="animation-delay:80ms">
        {error && (
          <div class="mb-5 bg-red-50 border border-red-200 rounded-xl p-3.5 flex items-center gap-2.5 text-sm text-red-700">
            <svg class="w-4 h-4 shrink-0 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {error === 'credenciales' ? 'Email o contraseña incorrectos.' : 'Error al iniciar sesión. Intenta de nuevo.'}
          </div>
        )}

        <form id="form-login" class="space-y-5">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="empresa@correo.cl"
                class="w-full border border-gray-300 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
              />
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="block text-sm font-semibold text-gray-700">Contraseña</label>
              <a href="/empleador/recuperar" class="text-xs text-brand-600 hover:text-brand-700 font-medium">¿Olvidaste tu contraseña?</a>
            </div>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
              <input
                type="password"
                name="password"
                required
                autocomplete="current-password"
                placeholder="Tu contraseña"
                class="w-full border border-gray-300 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-shadow"
              />
            </div>
          </div>

          <div id="login-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl p-3 flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span></span>
          </div>

          <button
            type="submit"
            id="btn-login"
            class="w-full bg-brand-600 text-white py-3 rounded-xl font-semibold hover:bg-brand-700 transition-colors disabled:opacity-60 shadow-sm text-sm"
          >
            Ingresar
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>

<style>
  @keyframes formEnter {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .form-enter { animation: formEnter 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
</style>

<script>
  const form = document.getElementById('form-login') as HTMLFormElement;
  const btn = document.getElementById('btn-login') as HTMLButtonElement;
  const errEl = document.getElementById('login-error') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Ingresando...';
    btn.disabled = true;
    errEl.classList.add('hidden');

    try {
      const body = new FormData(form);
      const res = await fetch('/api/auth/login', { method: 'POST', body });
      const data = await res.json();

      if (res.ok && data.ok) {
        window.location.href = '/empleador/dashboard';
      } else {
        const span = errEl.querySelector('span');
        if (span) span.textContent = data.error || 'Error al iniciar sesión.';
        errEl.classList.remove('hidden');
        btn.textContent = 'Ingresar';
        btn.disabled = false;
      }
    } catch {
      const span = errEl.querySelector('span');
      if (span) span.textContent = 'Error de conexión. Intenta de nuevo.';
      errEl.classList.remove('hidden');
      btn.textContent = 'Ingresar';
      btn.disabled = false;
    }
  });
</script>
