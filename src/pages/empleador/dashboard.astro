---
import Layout from '../../layouts/Layout.astro';
import { TIPOS } from '../../lib/constants';

const { client, empleador } = Astro.locals.session!;

const { data: ofertas } = await client
  .from('ofertas')
  .select(`
    id, titulo, tipo_empleo, comuna, activa, expira_en, created_at,
    postulaciones(count)
  `)
  .eq('empleador_id', empleador.id)
  .order('created_at', { ascending: false });

const now = new Date();

const ofertasActivas = ofertas?.filter(o => o.activa && new Date(o.expira_en) >= now).length ?? 0;
const ofertasExpiradas = ofertas?.filter(o => !o.activa || new Date(o.expira_en) < now).length ?? 0;
const totalPostulaciones = ofertas?.reduce((sum, o) => sum + ((o.postulaciones as { count: number }[])?.[0]?.count ?? 0), 0) ?? 0;

const ofertasDisplay = (ofertas ?? []).map((oferta) => {
  const expirada = new Date(oferta.expira_en) < now;
  const nPost = (oferta.postulaciones as { count: number }[])?.[0]?.count ?? 0;
  const estado = !oferta.activa ? 'Inactiva' : expirada ? 'Expirada' : 'Activa';
  const estadoColor = estado === 'Activa'
    ? 'text-emerald-700 bg-emerald-50 border-emerald-100'
    : estado === 'Expirada'
    ? 'text-amber-700 bg-amber-50 border-amber-100'
    : 'text-slate-500 bg-slate-100 border-slate-200';
  const diasRestantes = Math.max(0, Math.ceil((new Date(oferta.expira_en).getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
  const totalDias = Math.max(1, Math.ceil((new Date(oferta.expira_en).getTime() - new Date(oferta.created_at).getTime()) / (1000 * 60 * 60 * 24)));
  const pctTranscurrido = Math.min(100, Math.round(((totalDias - diasRestantes) / totalDias) * 100));
  const barColor = diasRestantes <= 3 ? 'bg-red-400' : diasRestantes <= 7 ? 'bg-orange-300' : 'bg-brand-400';
  const barWidth = 'width: ' + pctTranscurrido + '%';
  const diasLabel = diasRestantes === 0
    ? 'Último día'
    : diasRestantes + ' día' + (diasRestantes !== 1 ? 's' : '') + ' restante' + (diasRestantes !== 1 ? 's' : '');
  const urgencia = !expirada && oferta.activa && diasRestantes <= 3;
  return { ...oferta, expirada, nPost, estado, estadoColor, diasRestantes, barColor, barWidth, diasLabel, urgencia };
});

const email = Astro.locals.session?.user?.email ?? '';
---

<Layout title="Panel de empleador">
  <!-- Hero editorial -->
  <div class="relative overflow-hidden bg-gradient-to-br from-brand-800 via-brand-600 to-indigo-600 py-10 px-4">
    <div class="pointer-events-none absolute inset-0 bg-hero-mesh opacity-80" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -right-20 top-0 w-64 h-64 rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>

    <div class="relative max-w-5xl mx-auto">
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-2xl bg-white/15 border border-white/25 flex items-center justify-center text-white font-bold text-lg backdrop-blur shrink-0 shadow-glow">
            {empleador.empresa.slice(0, 2).toUpperCase()}
          </div>
          <div>
            <p class="text-brand-200/90 text-[11px] font-semibold tracking-widest uppercase">Panel empleador</p>
            <h1 class="text-2xl font-extrabold text-white tracking-tight">{empleador.empresa}</h1>
            {email && <p class="text-brand-100/80 text-xs mt-0.5">{email}</p>}
          </div>
        </div>
        <div class="flex gap-2">
          <a
            href="/empleador/oferta/nueva"
            class="bg-white text-brand-700 px-4 py-2.5 rounded-xl text-sm font-semibold hover:bg-brand-50 transition-all shadow-soft flex items-center gap-1.5"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
            </svg>
            Nueva oferta
          </a>
          <form action="/api/auth/logout" method="post">
            <button
              type="submit"
              class="text-sm text-white/85 border border-white/25 px-3.5 py-2.5 rounded-xl hover:bg-white/10 transition-colors font-medium"
            >
              Salir
            </button>
          </form>
        </div>
      </div>

      <!-- Métricas -->
      <div class="grid grid-cols-3 gap-3 mt-8">
        <div class="bg-white/10 border border-white/20 rounded-2xl p-4 sm:p-5 backdrop-blur text-center">
          <p id="metric-activas" data-target={ofertasActivas} class="text-3xl sm:text-4xl font-extrabold text-white tabular-nums">0</p>
          <p class="text-[11px] sm:text-xs text-brand-100/90 mt-1.5 font-semibold tracking-wide uppercase">Activas</p>
        </div>
        <div class="bg-white/10 border border-white/20 rounded-2xl p-4 sm:p-5 backdrop-blur text-center">
          <p id="metric-postulaciones" data-target={totalPostulaciones} class="text-3xl sm:text-4xl font-extrabold text-white tabular-nums">0</p>
          <p class="text-[11px] sm:text-xs text-brand-100/90 mt-1.5 font-semibold tracking-wide uppercase">Postulaciones</p>
        </div>
        <div class="bg-white/10 border border-white/20 rounded-2xl p-4 sm:p-5 backdrop-blur text-center">
          <p id="metric-expiradas" data-target={ofertasExpiradas} class="text-3xl sm:text-4xl font-extrabold text-white/55 tabular-nums">0</p>
          <p class="text-[11px] sm:text-xs text-brand-100/70 mt-1.5 font-semibold tracking-wide uppercase">Expiradas</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-8">
    {ofertasDisplay.length === 0 ? (
      <!-- Empty state editorial -->
      <div class="relative overflow-hidden text-center py-16 sm:py-20 px-6 bg-white border border-slate-200/90 rounded-3xl shadow-card ring-1 ring-slate-900/5">
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-brand-50/50 to-transparent" aria-hidden="true"></div>
        <div class="relative">
          <!-- Illustration light SVG -->
          <div class="mx-auto mb-6 w-28 h-28 rounded-3xl bg-gradient-to-br from-brand-50 to-indigo-50 border border-brand-100 flex items-center justify-center shadow-soft">
            <svg class="w-14 h-14 text-brand-400" fill="none" viewBox="0 0 64 64" aria-hidden="true">
              <rect x="12" y="14" width="40" height="36" rx="6" stroke="currentColor" stroke-width="2" class="text-brand-300"/>
              <path d="M22 28h20M22 36h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-brand-400"/>
              <circle cx="44" cy="42" r="10" fill="#eef2ff" stroke="#818cf8" stroke-width="2"/>
              <path d="M44 37v10M39 42h10" stroke="#4f46e5" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <p class="text-slate-900 font-extrabold text-xl tracking-tight mb-2">Tu tablero está listo</p>
          <p class="text-sm text-slate-500 max-w-md mx-auto leading-relaxed mb-8">
            Publica tu primera oferta en menos de 2 minutos. Los candidatos postulan con su CV
            y verás keywords automáticas aquí.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href="/empleador/oferta/nueva"
              class="inline-flex items-center gap-2 bg-gradient-to-r from-brand-600 to-brand-700 text-white px-6 py-3 rounded-xl text-sm font-semibold hover:from-brand-700 hover:to-brand-800 transition-all shadow-glow"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
              </svg>
              Publicar primera oferta
            </a>
            <a href="/" class="text-sm font-medium text-slate-500 hover:text-brand-700 transition-colors">
              Ver cómo se ven las ofertas →
            </a>
          </div>
          <!-- Mini tips -->
          <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-3 text-left max-w-lg mx-auto">
            {[
              { t: 'Plantillas', d: 'Tech, ventas, admin…' },
              { t: 'Keywords', d: 'Del CV al instante' },
              { t: 'Gratis', d: 'Sin tarjeta ni plan' },
            ].map((tip) => (
              <div class="rounded-xl bg-slate-50 border border-slate-100 px-3 py-2.5">
                <p class="text-xs font-bold text-slate-800">{tip.t}</p>
                <p class="text-[11px] text-slate-500 mt-0.5">{tip.d}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    ) : (
      <div>
        <div class="flex items-end justify-between gap-3 mb-5">
          <div>
            <h2 class="text-lg font-extrabold text-slate-900 tracking-tight">Tus ofertas</h2>
            <p class="text-sm text-slate-500 mt-0.5">
              {ofertasDisplay.length} publicaci{ofertasDisplay.length === 1 ? 'ón' : 'ones'}
              {totalPostulaciones > 0 && (
                <span> · <span class="font-semibold text-brand-600">{totalPostulaciones}</span> CV{totalPostulaciones !== 1 ? 's' : ''} en total</span>
              )}
            </p>
          </div>
          <a
            href="/empleador/oferta/nueva"
            class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-800 transition-colors"
          >
            + Nueva
          </a>
        </div>

        <div class="space-y-3">
          {ofertasDisplay.map((oferta) => (
            <div class={`bg-white border rounded-2xl p-4 sm:p-5 shadow-soft hover:shadow-card-hover hover:-translate-y-0.5 transition-all group ring-1 ring-slate-900/[0.03] ${oferta.urgencia ? 'border-amber-200/80' : 'border-slate-200/90'}`}>
              <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <h3 class="font-bold text-slate-900 group-hover:text-brand-700 transition-colors tracking-tight text-base">
                      {oferta.titulo}
                    </h3>
                    <span class={`text-[11px] px-2.5 py-0.5 rounded-full font-semibold border ${oferta.estadoColor}`}>
                      {oferta.estado}
                    </span>
                    {oferta.urgencia && (
                      <span class="text-[11px] px-2 py-0.5 rounded-full font-semibold bg-amber-50 text-amber-800 border border-amber-100">
                        Por vencer
                      </span>
                    )}
                  </div>
                  <p class="text-sm text-slate-500 mt-1.5 flex flex-wrap items-center gap-x-2 gap-y-0.5">
                    <span class="inline-flex items-center gap-1 font-medium">
                      <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      </svg>
                      {oferta.comuna}
                    </span>
                    <span class="text-slate-300">·</span>
                    <span>{TIPOS[oferta.tipo_empleo] || oferta.tipo_empleo}</span>
                    <span class="text-slate-300">·</span>
                    <span>Vence {new Date(oferta.expira_en).toLocaleDateString('es-CL')}</span>
                  </p>
                  {!oferta.expirada && oferta.activa && (
                    <div class="mt-3 max-w-xs">
                      <div class="bg-slate-100 rounded-full h-1 overflow-hidden">
                        <div class={`h-full rounded-full transition-all ${oferta.barColor}`} style={oferta.barWidth}></div>
                      </div>
                      <p class="text-[11px] text-slate-400 mt-1 font-medium">{oferta.diasLabel}</p>
                    </div>
                  )}
                </div>

                <div class="flex items-center gap-2 shrink-0 flex-wrap sm:flex-nowrap">
                  <div class={`text-center min-w-[3.25rem] px-3 py-2 rounded-xl border ${oferta.nPost > 0 ? 'bg-brand-50 border-brand-100' : 'bg-slate-50 border-slate-100'}`}>
                    <p class={`text-lg font-extrabold leading-none tabular-nums ${oferta.nPost > 0 ? 'text-brand-700' : 'text-slate-700'}`}>
                      {oferta.nPost}
                    </p>
                    <p class="text-[10px] text-slate-400 mt-1 font-semibold uppercase tracking-wide">
                      {oferta.nPost === 1 ? 'CV' : 'CVs'}
                    </p>
                  </div>
                  <a
                    href={`/oferta/${oferta.id}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-slate-400 border border-slate-200 p-2.5 rounded-xl hover:bg-slate-50 hover:text-slate-600 transition-colors"
                    title="Ver oferta pública"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                  <a
                    href={`/empleador/oferta/${oferta.id}/postulaciones`}
                    class="text-sm text-white bg-gradient-to-r from-brand-600 to-brand-700 px-3.5 py-2.5 rounded-xl hover:from-brand-700 hover:to-brand-800 transition-all font-semibold shadow-soft"
                  >
                    Ver CVs
                  </a>
                  <form action="/api/ofertas/desactivar" method="post" class="inline">
                    <input type="hidden" name="id" value={oferta.id} />
                    <button
                      type="submit"
                      class="text-sm text-slate-500 border border-slate-200 px-3 py-2.5 rounded-xl hover:bg-slate-50 transition-colors font-medium"
                      onclick="return confirm('¿Desactivar esta oferta?')"
                    >
                      {oferta.activa ? 'Desactivar' : 'Activar'}
                    </button>
                  </form>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target || '0', 10);
    if (target === 0) { el.textContent = '0'; return; }
    const duration = 800;
    const start = performance.now();
    const step = (now: number) => {
      const elapsed = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - elapsed, 3);
      el.textContent = String(Math.round(eased * target));
      if (elapsed < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  document.addEventListener('astro:page-load', () => {
    ['metric-activas', 'metric-postulaciones', 'metric-expiradas'].forEach(id => {
      const el = document.getElementById(id);
      if (el) animateCounter(el);
    });
  });
</script>
