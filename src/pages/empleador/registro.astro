---
import Layout from '../../layouts/Layout.astro';
import { getEmpleadorSession } from '../../lib/auth';

const session = await getEmpleadorSession(Astro.cookies);
if (session) return Astro.redirect('/empleador/dashboard');
---

<Layout title="Registro de empleador">
  <div class="max-w-md mx-auto px-4 py-16">
    <div class="bg-white border border-gray-200 rounded-lg p-8">
      <h1 class="text-xl font-bold text-gray-900 mb-1">Crear cuenta de empleador</h1>
      <p class="text-sm text-gray-500 mb-6">
        ¿Ya tienes cuenta?
        <a href="/empleador/login" class="text-brand-600 hover:underline">Inicia sesión</a>
      </p>

      <form id="form-registro" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nombre de la empresa</label>
          <input
            type="text"
            name="empresa"
            required
            placeholder="Empresa S.A."
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
          <input
            type="password"
            name="password"
            required
            minlength="8"
            autocomplete="new-password"
            placeholder="Mínimo 8 caracteres"
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>

        <div id="registro-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded p-2"></div>
        <div id="registro-ok" class="hidden text-sm text-green-700 bg-green-50 border border-green-200 rounded p-2"></div>

        <button
          type="submit"
          id="btn-registro"
          class="w-full bg-brand-600 text-white py-2.5 rounded font-medium hover:bg-brand-700 transition-colors disabled:opacity-60"
        >
          Crear cuenta
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('form-registro') as HTMLFormElement;
  const btn = document.getElementById('btn-registro') as HTMLButtonElement;
  const errEl = document.getElementById('registro-error') as HTMLDivElement;
  const okEl = document.getElementById('registro-ok') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Creando cuenta...';
    btn.disabled = true;
    errEl.classList.add('hidden');
    okEl.classList.add('hidden');

    const body = new FormData(form);
    const res = await fetch('/api/auth/registro', { method: 'POST', body });
    const data = await res.json();

    if (res.ok && data.ok) {
      if (data.requiresEmailConfirmation) {
        okEl.textContent = 'Cuenta creada. Revisa tu bandeja de entrada y confirma tu email para poder iniciar sesión.';
        okEl.classList.remove('hidden');
        btn.textContent = 'Cuenta creada';
      } else {
        okEl.textContent = '¡Cuenta creada! Redirigiendo al panel...';
        okEl.classList.remove('hidden');
        setTimeout(() => { window.location.href = '/empleador/dashboard'; }, 1500);
      }
    } else {
      errEl.textContent = data.error || 'Error al crear la cuenta.';
      errEl.classList.remove('hidden');
      btn.textContent = 'Crear cuenta';
      btn.disabled = false;
    }
  });
</script>
