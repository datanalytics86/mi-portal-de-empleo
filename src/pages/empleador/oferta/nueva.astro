---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Nueva oferta">
  <section class="mx-auto max-w-2xl rounded-xl border border-border bg-white p-6">
    <h2 class="text-2xl font-semibold text-text-primary">Publica una nueva oferta</h2>
    <p class="mt-2 text-sm text-text-secondary">Completa los datos esenciales y publica.</p>

    <form class="mt-6 grid gap-4">
      <label class="text-sm text-text-secondary">
        Título
        <input
          type="text"
          class="mt-2 w-full rounded-lg border border-border px-4 py-2 focus:border-accent focus:outline-none"
        />
      </label>
      <label class="text-sm text-text-secondary">
        Descripción
        <textarea
          rows={5}
          class="mt-2 w-full rounded-lg border border-border px-4 py-2 focus:border-accent focus:outline-none"
        ></textarea>
      </label>
      <div class="grid gap-4 md:grid-cols-2">
        <label class="text-sm text-text-secondary">
          Tipo de jornada
          <select class="mt-2 w-full rounded-lg border border-border px-4 py-2 focus:border-accent focus:outline-none">
            <option>Full-time</option>
            <option>Part-time</option>
            <option>Freelance</option>
            <option>Práctica</option>
          </select>
        </label>
        <label class="text-sm text-text-secondary">
          Comuna
          <select class="mt-2 w-full rounded-lg border border-border px-4 py-2 focus:border-accent focus:outline-none">
            <option>Santiago</option>
            <option>Providencia</option>
            <option>Ñuñoa</option>
            <option>Las Condes</option>
          </select>
        </label>
      </div>
      <button class="mt-2 w-full rounded-lg bg-accent px-4 py-3 text-sm font-semibold text-white hover:bg-accent-hover" type="submit">
        Publicar oferta
      </button>
    </form>
  </section>
</Layout>
