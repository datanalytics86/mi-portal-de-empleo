---
import Layout from '../../../layouts/Layout.astro';
import { getEmpleadorSession } from '../../../lib/auth';
import { COMUNAS_NOMBRES } from '../../../lib/comunas';

const session = await getEmpleadorSession(Astro.cookies);
if (!session) return Astro.redirect('/empleador/login');

// Fecha mínima (hoy) y máxima (6 meses) para expiración
const hoy = new Date().toISOString().split('T')[0];
const maxFecha = new Date();
maxFecha.setMonth(maxFecha.getMonth() + 6);
const maxFechaStr = maxFecha.toISOString().split('T')[0];

const CATEGORIAS = [
  'Tecnología', 'Ventas', 'Marketing', 'Finanzas', 'Administración',
  'Salud', 'Educación', 'Operaciones', 'Diseño', 'Legal', 'Otro',
];
---

<Layout title="Nueva oferta">
  <div class="max-w-2xl mx-auto px-4 py-8">
    <div class="flex items-center gap-3 mb-6">
      <a href="/empleador/dashboard" class="text-sm text-brand-600 hover:underline">← Dashboard</a>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg p-6">
      <h1 class="text-xl font-bold text-gray-900 mb-5">Publicar nueva oferta</h1>

      <form id="form-nueva" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Título del cargo <span class="text-red-500">*</span></label>
          <input
            type="text"
            name="titulo"
            required
            maxlength="120"
            placeholder="Ej: Desarrollador Full Stack"
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de empleo <span class="text-red-500">*</span></label>
            <select
              name="tipo_empleo"
              required
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            >
              <option value="">Seleccionar...</option>
              <option value="full-time">Full-time</option>
              <option value="part-time">Part-time</option>
              <option value="freelance">Freelance</option>
              <option value="practica">Práctica</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Categoría <span class="text-red-500">*</span></label>
            <select
              name="categoria"
              required
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            >
              <option value="">Seleccionar...</option>
              {CATEGORIAS.map(cat => <option value={cat}>{cat}</option>)}
            </select>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Comuna <span class="text-red-500">*</span></label>
          <select
            name="comuna"
            required
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          >
            <option value="">Seleccionar comuna...</option>
            {COMUNAS_NOMBRES.map(c => <option value={c}>{c}</option>)}
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Descripción del cargo <span class="text-red-500">*</span>
            <span id="char-count" class="text-gray-400 font-normal ml-1">0/2000</span>
          </label>
          <textarea
            name="descripcion"
            id="descripcion"
            required
            maxlength="2000"
            rows="8"
            placeholder="Describe las responsabilidades, requisitos y condiciones del puesto..."
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 resize-y"
          ></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de cierre <span class="text-red-500">*</span></label>
          <input
            type="date"
            name="expira_en"
            required
            min={hoy}
            max={maxFechaStr}
            class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>

        <div id="form-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded p-3"></div>

        <div class="flex gap-3 pt-2">
          <button
            type="submit"
            id="btn-publicar"
            class="flex-1 bg-brand-600 text-white py-2.5 rounded font-medium hover:bg-brand-700 transition-colors disabled:opacity-60"
          >
            Publicar oferta
          </button>
          <a
            href="/empleador/dashboard"
            class="px-4 py-2.5 text-sm text-gray-600 border border-gray-300 rounded hover:bg-gray-50 transition-colors"
          >
            Cancelar
          </a>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  // Contador de caracteres
  const textarea = document.getElementById('descripcion') as HTMLTextAreaElement;
  const charCount = document.getElementById('char-count');
  textarea?.addEventListener('input', () => {
    if (charCount) charCount.textContent = `${textarea.value.length}/2000`;
  });

  // Envío del formulario
  const form = document.getElementById('form-nueva') as HTMLFormElement;
  const btn = document.getElementById('btn-publicar') as HTMLButtonElement;
  const errEl = document.getElementById('form-error') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Publicando...';
    btn.disabled = true;
    errEl.classList.add('hidden');

    const body = new FormData(form);
    const res = await fetch('/api/ofertas/nueva', { method: 'POST', body });
    const data = await res.json();

    if (res.ok && data.ok) {
      window.location.href = '/empleador/dashboard';
    } else {
      errEl.textContent = data.error || 'Error al publicar. Intenta de nuevo.';
      errEl.classList.remove('hidden');
      btn.textContent = 'Publicar oferta';
      btn.disabled = false;
    }
  });
</script>
