---
import Layout from '../../../layouts/Layout.astro';
import { COMUNAS_NOMBRES } from '../../../lib/comunas';
import { CATEGORIAS } from '../../../lib/constants';

// Fecha mínima (hoy) y máxima (6 meses) para expiración
const hoy = new Date().toISOString().split('T')[0];
const maxFecha = new Date();
maxFecha.setMonth(maxFecha.getMonth() + 6);
const maxFechaStr = maxFecha.toISOString().split('T')[0];

---

<Layout title="Nueva oferta">
  <!-- Mini hero -->
  <div class="bg-gradient-to-br from-brand-700 via-brand-600 to-indigo-700 py-8 px-4">
    <div class="max-w-2xl mx-auto">
      <a href="/empleador/dashboard" class="inline-flex items-center gap-1.5 text-brand-200 hover:text-white text-sm transition-colors mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Dashboard
      </a>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-white/20 border border-white/30 flex items-center justify-center backdrop-blur shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
        </div>
        <div>
          <h1 class="text-xl font-bold text-white">Publicar nueva oferta</h1>
          <p class="text-brand-200 text-sm">Completa los detalles del cargo a publicar</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-2xl mx-auto px-4 py-8">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 sm:p-8">
      <form id="form-nueva" class="space-y-5">

        <!-- Título -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">
            Título del cargo <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <input
              type="text"
              name="titulo"
              required
              maxlength="120"
              placeholder="Ej: Desarrollador Full Stack"
              class="w-full border border-gray-300 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
            />
          </div>
        </div>

        <!-- Tipo + Categoría -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
              Tipo de empleo <span class="text-red-500">*</span>
            </label>
            <select
              name="tipo_empleo"
              required
              class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-gray-700 bg-white"
            >
              <option value="">Seleccionar...</option>
              <option value="full-time">Full-time</option>
              <option value="part-time">Part-time</option>
              <option value="freelance">Freelance</option>
              <option value="practica">Práctica</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
              Categoría <span class="text-red-500">*</span>
            </label>
            <select
              name="categoria"
              required
              class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-gray-700 bg-white"
            >
              <option value="">Seleccionar...</option>
              {CATEGORIAS.map(cat => <option value={cat}>{cat}</option>)}
            </select>
          </div>
        </div>

        <!-- Comuna -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">
            Comuna <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <select
              name="comuna"
              required
              class="w-full border border-gray-300 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-gray-700 bg-white appearance-none"
            >
              <option value="">Seleccionar comuna...</option>
              {COMUNAS_NOMBRES.map(c => <option value={c}>{c}</option>)}
            </select>
          </div>
        </div>

        <!-- Descripción -->
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <label class="block text-sm font-semibold text-gray-700">
              Descripción del cargo <span class="text-red-500">*</span>
            </label>
            <span id="char-count" class="text-xs text-gray-400 tabular-nums">0 / 2000</span>
          </div>
          <!-- Plantillas rápidas (rellenan descripción + categoría/tipo) -->
          <div class="flex flex-wrap gap-1.5 mb-2">
            <span class="text-xs text-gray-400 flex items-center pr-1">Plantilla:</span>
            <button type="button" class="tpl-btn text-xs text-brand-600 border border-brand-200 bg-brand-50 px-2.5 py-1 rounded-lg hover:bg-brand-100 transition-colors font-medium" data-tpl="tech">
              Tecnología
            </button>
            <button type="button" class="tpl-btn text-xs text-brand-600 border border-brand-200 bg-brand-50 px-2.5 py-1 rounded-lg hover:bg-brand-100 transition-colors font-medium" data-tpl="ventas">
              Ventas
            </button>
            <button type="button" class="tpl-btn text-xs text-brand-600 border border-brand-200 bg-brand-50 px-2.5 py-1 rounded-lg hover:bg-brand-100 transition-colors font-medium" data-tpl="admin">
              Admin
            </button>
            <button type="button" class="tpl-btn text-xs text-brand-600 border border-brand-200 bg-brand-50 px-2.5 py-1 rounded-lg hover:bg-brand-100 transition-colors font-medium" data-tpl="practica">
              Práctica
            </button>
          </div>
          <textarea
            name="descripcion"
            id="descripcion"
            required
            maxlength="2000"
            rows="8"
            placeholder="Describe las responsabilidades, requisitos y condiciones del puesto..."
            class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y"
          ></textarea>
          <!-- Barra de progreso de caracteres -->
          <div class="mt-1.5 bg-gray-100 rounded-full h-0.5 overflow-hidden">
            <div id="char-bar" class="h-full rounded-full bg-brand-400 transition-all duration-150" style="width: 0%"></div>
          </div>
        </div>

        <!-- Fecha de cierre -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">
            Fecha de cierre <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <input
              type="date"
              name="expira_en"
              required
              min={hoy}
              max={maxFechaStr}
              class="w-full border border-gray-300 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-gray-700"
            />
          </div>
        </div>

        <!-- Error -->
        <div id="form-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl p-3 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span id="form-error-txt"></span>
        </div>

        <!-- Botones -->
        <div class="flex gap-3 pt-2">
          <button
            type="submit"
            id="btn-publicar"
            class="flex-1 inline-flex items-center justify-center gap-2 bg-brand-600 text-white py-3 rounded-xl font-semibold hover:bg-brand-700 transition-colors disabled:opacity-60 shadow-sm text-sm"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
            <span id="btn-txt">Publicar oferta</span>
          </button>
          <a
            href="/empleador/dashboard"
            class="px-5 py-3 text-sm text-gray-600 border border-gray-300 rounded-xl hover:bg-gray-50 transition-colors font-medium"
          >
            Cancelar
          </a>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  type Plantilla = {
    titulo: string;
    categoria: string;
    tipo_empleo: string;
    descripcion: string;
  };

  const PLANTILLAS: Record<string, Plantilla> = {
    tech: {
      titulo: 'Desarrollador/a Full Stack',
      categoria: 'Tecnología',
      tipo_empleo: 'full-time',
      descripcion: `Buscamos un/a Desarrollador/a Full Stack para construir y mantener productos digitales de alto impacto.

Responsabilidades:
• Desarrollar y mantener aplicaciones web (frontend y/o backend)
• Participar en code reviews y buenas prácticas
• Colaborar con producto, diseño y otros equipos

Requisitos:
• Experiencia con JavaScript/TypeScript, React o similar
• Conocimiento de APIs REST y bases de datos (SQL)
• Trabajo en equipo y metodologías ágiles (Scrum/Kanban)

Ofrecemos:
• Modalidad híbrida o remota (según acuerdo)
• Sueldo competitivo según experiencia
• Stack moderno y aprendizaje continuo`,
    },
    ventas: {
      titulo: 'Ejecutivo/a de Ventas',
      categoria: 'Ventas',
      tipo_empleo: 'full-time',
      descripcion: `Buscamos un/a Ejecutivo/a de Ventas para expandir nuestra cartera de clientes en Chile.

Responsabilidades:
• Prospección y captación de nuevos clientes
• Cumplimiento de metas comerciales mensuales
• Seguimiento postventa y fidelización

Requisitos:
• Experiencia en ventas (mínimo 1 año)
• Alta orientación a resultados y metas
• Excelentes habilidades de comunicación y negociación

Ofrecemos:
• Sueldo base + comisiones
• Capacitación inicial y continua
• Incentivos por cumplimiento de metas`,
    },
    admin: {
      titulo: 'Asistente Administrativo/a',
      categoria: 'Administración',
      tipo_empleo: 'full-time',
      descripcion: `Buscamos un/a Asistente Administrativo/a para apoyar la operación diaria del equipo.

Responsabilidades:
• Gestión de documentos, agenda y correspondencia
• Apoyo en facturación, compras y control de gastos
• Atención a proveedores y coordinación interna

Requisitos:
• Manejo avanzado de Excel y herramientas Office
• Organización, proactividad y atención al detalle
• Experiencia previa en roles administrativos (deseable)

Ofrecemos:
• Buen ambiente laboral
• Horario full-time
• Sueldo a convenir según experiencia`,
    },
    practica: {
      titulo: 'Practicante',
      categoria: 'Otro',
      tipo_empleo: 'practica',
      descripcion: `Abrimos cupo de práctica profesional / laboral para estudiantes o egresados recientes.

Responsabilidades:
• Apoyar al equipo en tareas del día a día del área
• Participar en proyectos reales con supervisión
• Aprender herramientas y procesos de la industria

Requisitos:
• Estudiante de últimos años o egresado/a reciente
• Ganas de aprender, responsabilidad y proactividad
• Disponibilidad de [X] horas semanales

Ofrecemos:
• Tutoría y feedback continuo
• Experiencia real en el rubro
• Posibilidad de continuidad según desempeño
• (Indicar si es con o sin remuneración)`,
    },
  };

  // Contador de caracteres + barra de progreso
  const textarea = document.getElementById('descripcion') as HTMLTextAreaElement;
  const charCount = document.getElementById('char-count');
  const charBar = document.getElementById('char-bar') as HTMLElement;
  const formEl = document.getElementById('form-nueva') as HTMLFormElement;

  function updateCharCount() {
    const len = textarea.value.length;
    const max = 2000;
    if (charCount) charCount.textContent = `${len} / ${max}`;
    if (charBar) {
      const pct = Math.min(100, (len / max) * 100);
      charBar.style.width = pct + '%';
      charBar.className = 'h-full rounded-full transition-all duration-150 ' +
        (pct >= 90 ? 'bg-red-400' : pct >= 70 ? 'bg-orange-400' : 'bg-brand-400');
    }
  }

  textarea?.addEventListener('input', updateCharCount);

  // Plantillas rápidas: descripción + categoría + tipo (+ título si vacío)
  document.querySelectorAll<HTMLButtonElement>('.tpl-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.tpl;
      const tpl = key ? PLANTILLAS[key] : undefined;
      if (!tpl) return;
      if (textarea.value && !confirm('¿Reemplazar la descripción actual con la plantilla?')) return;

      textarea.value = tpl.descripcion;
      updateCharCount();

      const cat = formEl?.querySelector<HTMLSelectElement>('[name="categoria"]');
      const tipo = formEl?.querySelector<HTMLSelectElement>('[name="tipo_empleo"]');
      const titulo = formEl?.querySelector<HTMLInputElement>('[name="titulo"]');
      if (cat) cat.value = tpl.categoria;
      if (tipo) tipo.value = tpl.tipo_empleo;
      if (titulo && !titulo.value.trim()) titulo.value = tpl.titulo;

      textarea.focus();
    });
  });

  // Envío del formulario
  const form = document.getElementById('form-nueva') as HTMLFormElement;
  const btn = document.getElementById('btn-publicar') as HTMLButtonElement;
  const btnTxt = document.getElementById('btn-txt');
  const errEl = document.getElementById('form-error') as HTMLDivElement;
  const errTxt = document.getElementById('form-error-txt');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (btnTxt) btnTxt.textContent = 'Publicando...';
    btn.disabled = true;
    errEl.classList.add('hidden');

    const body = new FormData(form);
    const res = await fetch('/api/ofertas/nueva', { method: 'POST', body });
    const data = await res.json();

    if (res.ok && data.ok) {
      window.location.href = '/empleador/dashboard';
    } else {
      if (errTxt) errTxt.textContent = data.error || 'Error al publicar. Intenta de nuevo.';
      errEl.classList.remove('hidden');
      if (btnTxt) btnTxt.textContent = 'Publicar oferta';
      btn.disabled = false;
    }
  });
</script>
