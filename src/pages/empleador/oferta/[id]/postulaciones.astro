---
import Layout from '../../../../layouts/Layout.astro';

const { id } = Astro.params;
if (!id) return Astro.redirect('/empleador/dashboard');

const { client, empleador } = Astro.locals.session!;

// Verificar que la oferta pertenece al empleador
const { data: oferta, error: ofertaError } = await client
  .from('ofertas')
  .select('id, titulo, empresa, activa')
  .eq('id', id)
  .eq('empleador_id', empleador.id)
  .single();

if (ofertaError || !oferta) return Astro.redirect('/empleador/dashboard');

// Obtener postulaciones
const { data: postulaciones } = await client
  .from('postulaciones')
  .select('id, nombre, email, cv_url, created_at')
  .eq('oferta_id', id)
  .order('created_at', { ascending: false });
---

<Layout title={`Postulaciones: ${oferta.titulo}`}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex items-center gap-3 mb-6">
      <a href="/empleador/dashboard" class="text-sm text-brand-600 hover:underline">← Dashboard</a>
    </div>

    <div class="mb-5">
      <h1 class="text-xl font-bold text-gray-900">{oferta.titulo}</h1>
      <p class="text-sm text-gray-500 mt-1">
        {postulaciones?.length ?? 0} postulaci{(postulaciones?.length ?? 0) === 1 ? 'ón' : 'ones'} recibida{(postulaciones?.length ?? 0) === 1 ? '' : 's'}
      </p>
    </div>

    {!postulaciones || postulaciones.length === 0 ? (
      <div class="bg-white border border-gray-200 rounded-lg p-12 text-center text-gray-500">
        Aún no hay postulaciones para esta oferta.
      </div>
    ) : (
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-gray-700">Candidato</th>
              <th class="text-left px-4 py-3 font-medium text-gray-700">Email</th>
              <th class="text-left px-4 py-3 font-medium text-gray-700">Fecha</th>
              <th class="text-left px-4 py-3 font-medium text-gray-700">CV</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {postulaciones.map((p) => (
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 text-gray-900">{p.nombre || <span class="text-gray-400 italic">Anónimo</span>}</td>
                <td class="px-4 py-3 text-gray-600">{p.email || <span class="text-gray-400">—</span>}</td>
                <td class="px-4 py-3 text-gray-500 whitespace-nowrap">
                  {new Date(p.created_at).toLocaleDateString('es-CL', {
                    year: 'numeric', month: 'short', day: 'numeric',
                    hour: '2-digit', minute: '2-digit',
                  })}
                </td>
                <td class="px-4 py-3">
                  <a
                    href={`/api/postulaciones/cv?id=${p.id}`}
                    target="_blank"
                    class="text-brand-600 hover:underline font-medium"
                  >
                    Descargar CV
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</Layout>
