---
import Layout from '../../../../layouts/Layout.astro';

const { id } = Astro.params;
if (!id) return Astro.redirect('/empleador/dashboard');

const { client, empleador } = Astro.locals.session!;

// Verificar que la oferta pertenece al empleador
const { data: oferta, error: ofertaError } = await client
  .from('ofertas')
  .select('id, titulo, empresa, activa')
  .eq('id', id)
  .eq('empleador_id', empleador.id)
  .single();

if (ofertaError || !oferta) return Astro.redirect('/empleador/dashboard');

// Obtener postulaciones
const { data: postulaciones } = await client
  .from('postulaciones')
  .select('id, nombre, email, cv_url, palabras_clave, created_at')
  .eq('oferta_id', id)
  .order('created_at', { ascending: false });

const total = postulaciones?.length ?? 0;
const emailsList = postulaciones?.filter(p => p.email).map(p => p.email) ?? [];
const hasEmails = emailsList.length > 0;
const csvRows = (postulaciones ?? []).map(p => ({
  nombre: p.nombre || 'Anónimo',
  email: p.email || '',
  fecha: new Date(p.created_at).toLocaleDateString('es-CL'),
  keywords: (p.palabras_clave ?? []).join(' | '),
}));
---

<Layout title={`Postulaciones: ${oferta.titulo}`}>
  <!-- Hero header -->
  <div class="bg-gradient-to-br from-brand-700 via-brand-600 to-indigo-700 py-8 px-4">
    <div class="max-w-5xl mx-auto">
      <a href="/empleador/dashboard" class="inline-flex items-center gap-1.5 text-brand-200 hover:text-white text-sm transition-colors mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Dashboard
      </a>
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-white leading-tight">{oferta.titulo}</h1>
          <p class="text-brand-200 text-sm mt-1">{oferta.empresa}</p>
        </div>
        <div class="flex items-center gap-3 flex-wrap">
          <!-- Exportar todos los emails -->
          {hasEmails && (
            <button
              id="btn-copiar-emails"
              data-emails={emailsList.join(', ')}
              class="inline-flex items-center gap-1.5 text-sm font-medium bg-white/15 border border-white/25 text-white px-3 py-2 rounded-lg hover:bg-white/25 transition-colors backdrop-blur"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
              </svg>
              <span id="copiar-emails-txt">Copiar emails ({emailsList.length})</span>
            </button>
          )}
          {total > 0 && (
            <button
              id="btn-export-csv"
              class="inline-flex items-center gap-1.5 text-sm font-medium bg-white/15 border border-white/25 text-white px-3 py-2 rounded-lg hover:bg-white/25 transition-colors backdrop-blur"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Exportar CSV
            </button>
          )}
          <a
            href={`/oferta/${oferta.id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium bg-white/15 border border-white/25 text-white px-3 py-2 rounded-lg hover:bg-white/25 transition-colors backdrop-blur"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Ver oferta
          </a>
          <div class="bg-white/15 border border-white/25 rounded-xl px-4 py-2.5 text-center backdrop-blur shrink-0">
            <p class="text-2xl font-extrabold text-white">{total}</p>
            <p class="text-xs text-brand-200 mt-0.5">{total === 1 ? 'postulación' : 'postulaciones'}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-8">
    {total === 0 ? (
      <div class="bg-white border border-gray-200 rounded-2xl p-16 text-center shadow-sm">
        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <p class="text-gray-800 font-semibold text-lg">Aún no hay postulaciones</p>
        <p class="text-sm text-gray-400 mt-1">Las candidaturas aparecerán aquí cuando lleguen.</p>
        <a
          href={`/oferta/${oferta.id}`}
          target="_blank"
          class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-800 transition-colors"
        >
          Ver oferta pública
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    ) : (
      <div>
        <!-- Sort toolbar -->
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm text-gray-500">
            <span class="font-semibold text-gray-900">{total}</span> candidato{total !== 1 ? 's' : ''}
          </p>
          <div class="flex items-center gap-1.5">
            <span class="text-xs text-gray-400 mr-1">Ordenar:</span>
            <button id="sort-fecha" class="sort-btn text-xs px-2.5 py-1 rounded-lg border border-brand-200 bg-brand-50 text-brand-700 font-medium transition-colors">
              Más reciente
            </button>
            <button id="sort-nombre" class="sort-btn text-xs px-2.5 py-1 rounded-lg border border-gray-200 text-gray-500 font-medium hover:bg-gray-50 transition-colors">
              A-Z
            </button>
          </div>
        </div>
        <div id="candidates-list" class="space-y-3">
        {postulaciones!.map((p, i) => {
          const initials = (p.nombre || '?')
            .split(' ')
            .slice(0, 2)
            .map((w: string) => w[0] || '')
            .join('')
            .toUpperCase()
            .slice(0, 2);
          const colors = [
            'bg-brand-100 text-brand-700',
            'bg-indigo-100 text-indigo-700',
            'bg-emerald-100 text-emerald-700',
            'bg-amber-100 text-amber-700',
            'bg-rose-100 text-rose-700',
          ];
          const color = colors[i % colors.length];
          const animDelay = 'animation-delay: ' + (i * 60) + 'ms';
          return (
            <div
              class="card-anim candidate-row bg-white border border-gray-200 rounded-2xl p-5 shadow-sm hover:border-brand-300 hover:shadow-md hover:-translate-y-0.5 transition-all"
              style={animDelay}
              data-nombre={p.nombre || ''}
              data-email={p.email || ''}
              data-fecha={p.created_at}
            >
              <div class="flex items-start gap-4">
                <!-- Avatar con badge numérico -->
                <div class="relative shrink-0">
                  <div class={`w-11 h-11 rounded-xl flex items-center justify-center font-bold text-sm ${color}`}>
                    {initials}
                  </div>
                  <span class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-gray-800 text-white text-[10px] font-bold rounded-full flex items-center justify-center leading-none">
                    {i + 1}
                  </span>
                </div>

                <!-- Info principal -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-3 flex-wrap">
                    <div>
                      <p class="font-semibold text-gray-900">
                        {p.nombre || <span class="text-gray-400 italic font-normal">Anónimo</span>}
                      </p>
                      {p.email ? (
                        <div class="flex items-center gap-1.5 mt-0.5">
                          <a href={`mailto:${p.email}`} class="text-sm text-brand-600 hover:underline">
                            {p.email}
                          </a>
                          <button
                            class="copy-email-btn text-gray-300 hover:text-gray-500 transition-colors p-0.5 rounded"
                            data-email={p.email}
                            title="Copiar email"
                          >
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                            </svg>
                          </button>
                        </div>
                      ) : (
                        <p class="text-sm text-gray-400 mt-0.5">Sin email</p>
                      )}
                    </div>
                    <div class="flex items-center gap-3 shrink-0">
                      <span
                        class="relative-time text-xs text-gray-400 whitespace-nowrap"
                        data-time={p.created_at}
                        title={new Date(p.created_at).toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' })}
                      >
                        {new Date(p.created_at).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' })}
                      </span>
                      <a
                        href={`/api/postulaciones/cv?id=${p.id}`}
                        target="_blank"
                        class="inline-flex items-center gap-1.5 bg-brand-600 text-white text-xs font-semibold px-3 py-1.5 rounded-lg hover:bg-brand-700 transition-colors shadow-sm"
                      >
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Descargar CV
                      </a>
                    </div>
                  </div>

                  <!-- Palabras clave -->
                  {p.palabras_clave && p.palabras_clave.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-3">
                      {p.palabras_clave.slice(0, 12).map((k: string) => (
                        <span class="text-xs bg-indigo-50 text-indigo-700 border border-indigo-100 px-2 py-0.5 rounded-full font-medium">
                          {k}
                        </span>
                      ))}
                      {p.palabras_clave.length > 12 && (
                        <span class="text-xs text-gray-400 px-1 py-0.5">+{p.palabras_clave.length - 12} más</span>
                      )}
                    </div>
                  )}
                </div>
              </div>
            </div>
          );
        })}

          <!-- Footer con total -->
          <p class="text-center text-xs text-gray-400 pt-2">
            Mostrando {total} postulaci{total === 1 ? 'ón' : 'ones'} · Los CVs se eliminan automáticamente a los 90 días
          </p>
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    // Tiempos relativos
    document.querySelectorAll<HTMLElement>('.relative-time').forEach(el => {
      const iso = el.dataset.time;
      if (!iso) return;
      const diff = Date.now() - new Date(iso).getTime();
      const mins = Math.floor(diff / 60000);
      const hours = Math.floor(diff / 3600000);
      const days = Math.floor(diff / 86400000);
      if (mins < 1) el.textContent = 'Ahora';
      else if (mins < 60) el.textContent = `hace ${mins} min`;
      else if (hours < 24) el.textContent = `hace ${hours} h`;
      else if (days === 1) el.textContent = 'ayer';
      else if (days < 30) el.textContent = `hace ${days} días`;
      else el.textContent = new Date(iso).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' });
    });

    // Copiar email individual
    document.querySelectorAll<HTMLButtonElement>('.copy-email-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const email = btn.dataset.email;
        if (!email) return;
        await navigator.clipboard.writeText(email).catch(() => {});
        const prev = btn.innerHTML;
        btn.innerHTML = '<svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(() => { btn.innerHTML = prev; }, 2000);
      });
    });

    // Copiar todos los emails
    const btnTodos = document.getElementById('btn-copiar-emails');
    const txtTodos = document.getElementById('copiar-emails-txt');
    btnTodos?.addEventListener('click', async () => {
      const emails = btnTodos.dataset.emails;
      if (!emails) return;
      await navigator.clipboard.writeText(emails).catch(() => {});
      if (txtTodos) {
        const original = txtTodos.textContent;
        txtTodos.textContent = '¡Copiado!';
        setTimeout(() => { if (txtTodos) txtTodos.textContent = original; }, 2000);
      }
    });
  });
</script>

<script define:vars={{ csvRows, ofertaTitulo: oferta.titulo }}>
  document.addEventListener('astro:page-load', () => {
    // CSV export
    const btnCSV = document.getElementById('btn-export-csv');
    btnCSV?.addEventListener('click', () => {
      const header = ['Nombre', 'Email', 'Fecha', 'Palabras clave'];
      const rows = csvRows.map((r) => [r.nombre, r.email, r.fecha, r.keywords]);
      const csv = [header, ...rows]
        .map(row => row.map(v => `"${String(v).replace(/"/g, '""')}"`).join(','))
        .join('\n');
      const a = document.createElement('a');
      a.href = 'data:text/csv;charset=utf-8,\uFEFF' + encodeURIComponent(csv);
      a.download = `postulaciones-${ofertaTitulo.replace(/[^a-z0-9]/gi, '-').toLowerCase()}.csv`;
      a.click();
    });

    // Sort candidates
    const list = document.getElementById('candidates-list');
    const btnFecha = document.getElementById('sort-fecha');
    const btnNombre = document.getElementById('sort-nombre');

    function sortCards(by: 'fecha' | 'nombre') {
      if (!list) return;
      const cards = Array.from(list.querySelectorAll<HTMLElement>('.candidate-row'));
      cards.sort((a, b) => {
        if (by === 'nombre') {
          return (a.dataset.nombre || '').localeCompare(b.dataset.nombre || '', 'es', { sensitivity: 'base' });
        }
        return new Date(b.dataset.fecha || 0).getTime() - new Date(a.dataset.fecha || 0).getTime();
      });
      cards.forEach(c => list.appendChild(c));
      // Toggle active state on buttons
      btnFecha?.classList.toggle('bg-brand-50', by === 'fecha');
      btnFecha?.classList.toggle('text-brand-700', by === 'fecha');
      btnFecha?.classList.toggle('border-brand-200', by === 'fecha');
      btnFecha?.classList.toggle('text-gray-500', by !== 'fecha');
      btnFecha?.classList.toggle('border-gray-200', by !== 'fecha');
      btnNombre?.classList.toggle('bg-brand-50', by === 'nombre');
      btnNombre?.classList.toggle('text-brand-700', by === 'nombre');
      btnNombre?.classList.toggle('border-brand-200', by === 'nombre');
      btnNombre?.classList.toggle('text-gray-500', by !== 'nombre');
      btnNombre?.classList.toggle('border-gray-200', by !== 'nombre');
    }

    btnFecha?.addEventListener('click', () => sortCards('fecha'));
    btnNombre?.addEventListener('click', () => sortCards('nombre'));
  });
</script>

<style>
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .card-anim {
    animation: fadeSlideUp 0.35s ease both;
  }
</style>
