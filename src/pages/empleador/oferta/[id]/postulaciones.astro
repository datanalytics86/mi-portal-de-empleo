---
import Layout from '../../../../layouts/Layout.astro';

const { id } = Astro.params;
if (!id) return Astro.redirect('/empleador/dashboard');

const { client, empleador } = Astro.locals.session!;

// Verificar que la oferta pertenece al empleador
const { data: oferta, error: ofertaError } = await client
  .from('ofertas')
  .select('id, titulo, empresa, activa')
  .eq('id', id)
  .eq('empleador_id', empleador.id)
  .single();

if (ofertaError || !oferta) return Astro.redirect('/empleador/dashboard');

// Obtener postulaciones — default: mejor match primero, luego más recientes
const { data: postulacionesRaw } = await client
  .from('postulaciones')
  .select('id, nombre, email, cv_url, palabras_clave, keywords, cv_parsed, parse_status, parsed_at, match_score, created_at')
  .eq('oferta_id', id)
  .order('created_at', { ascending: false });

// Sort en servidor: match_score DESC (nulls al final), luego fecha
const postulaciones = [...(postulacionesRaw ?? [])].sort((a, b) => {
  const sa = a.match_score ?? -1;
  const sb = b.match_score ?? -1;
  if (sb !== sa) return sb - sa;
  return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
});

const total = postulaciones.length;
const emailsList = postulaciones.filter(p => p.email).map(p => p.email);
const hasEmails = emailsList.length > 0;
const csvRows = postulaciones.map(p => {
  const parsed = p.cv_parsed as {
    titulo_profesional?: string | null;
    resumen?: string | null;
    telefono?: string | null;
    anos_experiencia?: number | null;
    ubicacion?: string | null;
  } | null;
  const kws = (p.keywords?.length ? p.keywords : p.palabras_clave) ?? [];
  return {
    nombre: p.nombre || parsed?.titulo_profesional || 'Anónimo',
    email: p.email || '',
    telefono: parsed?.telefono || '',
    fecha: new Date(p.created_at).toLocaleDateString('es-CL'),
    keywords: kws.join(' | '),
    match_score: p.match_score ?? '',
    titulo: parsed?.titulo_profesional || '',
    anos: parsed?.anos_experiencia ?? '',
    ubicacion: parsed?.ubicacion || '',
  };
});

function scoreClasses(score: number | null | undefined): string {
  if (score == null) return 'bg-gray-100 text-gray-500 border-gray-200';
  if (score >= 70) return 'bg-emerald-50 text-emerald-700 border-emerald-200';
  if (score >= 40) return 'bg-amber-50 text-amber-700 border-amber-200';
  return 'bg-rose-50 text-rose-700 border-rose-200';
}
---

<Layout title={`Postulaciones: ${oferta.titulo}`}>
  <!-- Hero header -->
  <div class="relative overflow-hidden bg-gradient-to-br from-brand-800 via-brand-600 to-indigo-600 py-9 px-4">
    <div class="pointer-events-none absolute inset-0 bg-hero-mesh opacity-80" aria-hidden="true"></div>
    <div class="relative max-w-5xl mx-auto">
      <a href="/empleador/dashboard" class="inline-flex items-center gap-1.5 text-brand-100 hover:text-white text-sm font-medium transition-colors mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Dashboard
      </a>
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <p class="text-brand-200/90 text-[11px] font-semibold tracking-widest uppercase mb-1">Postulaciones</p>
          <h1 class="text-xl sm:text-2xl font-extrabold text-white leading-tight tracking-tight">{oferta.titulo}</h1>
          <p class="text-brand-100 text-sm mt-1 font-medium">{oferta.empresa}</p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          {hasEmails && (
            <button
              id="btn-copiar-emails"
              data-emails={emailsList.join(', ')}
              class="inline-flex items-center gap-1.5 text-sm font-medium bg-white/10 border border-white/20 text-white px-3 py-2 rounded-xl hover:bg-white/20 transition-colors backdrop-blur"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
              </svg>
              <span id="copiar-emails-txt">Copiar emails ({emailsList.length})</span>
            </button>
          )}
          {total > 0 && (
            <button
              id="btn-export-csv"
              class="inline-flex items-center gap-1.5 text-sm font-medium bg-white/10 border border-white/20 text-white px-3 py-2 rounded-xl hover:bg-white/20 transition-colors backdrop-blur"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Exportar CSV
            </button>
          )}
          <a
            href={`/oferta/${oferta.id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium bg-white/10 border border-white/20 text-white px-3 py-2 rounded-xl hover:bg-white/20 transition-colors backdrop-blur"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Ver oferta
          </a>
          <div class="bg-white/15 border border-white/25 rounded-2xl px-4 py-2.5 text-center backdrop-blur shrink-0">
            <p class="text-2xl font-extrabold text-white tabular-nums">{total}</p>
            <p class="text-[10px] text-brand-100 mt-0.5 font-semibold uppercase tracking-wide">{total === 1 ? 'postulación' : 'postulaciones'}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-8">
    {total === 0 ? (
      <div class="relative overflow-hidden bg-white border border-slate-200/90 rounded-3xl p-12 sm:p-16 text-center shadow-card ring-1 ring-slate-900/5">
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-slate-50 to-transparent" aria-hidden="true"></div>
        <div class="relative">
          <div class="mx-auto mb-5 w-24 h-24 rounded-3xl bg-gradient-to-br from-slate-50 to-brand-50 border border-slate-100 flex items-center justify-center shadow-soft">
            <svg class="w-12 h-12 text-brand-300" fill="none" viewBox="0 0 64 64" aria-hidden="true">
              <circle cx="24" cy="24" r="8" stroke="currentColor" stroke-width="2"/>
              <circle cx="42" cy="26" r="6" stroke="currentColor" stroke-width="2" opacity="0.6"/>
              <path d="M10 48c2-8 8-12 14-12s12 4 14 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M36 48c1-5 4-8 8-8s6 2 8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
            </svg>
          </div>
          <p class="text-slate-900 font-extrabold text-xl tracking-tight">Aún no hay candidatos</p>
          <p class="text-sm text-slate-500 mt-2 max-w-sm mx-auto leading-relaxed">
            Comparte el link de la oferta. Cuando alguien postule, verás su CV, keywords y match aquí.
          </p>
          <div class="mt-7 flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href={`/oferta/${oferta.id}`}
              target="_blank"
              class="inline-flex items-center gap-2 bg-gradient-to-r from-brand-600 to-brand-700 text-white text-sm font-semibold px-5 py-2.5 rounded-xl hover:from-brand-700 hover:to-brand-800 transition-all shadow-soft"
            >
              Ver oferta pública
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
            <button
              type="button"
              id="btn-copy-offer-empty"
              data-url={`/oferta/${oferta.id}`}
              class="text-sm font-semibold text-brand-600 hover:text-brand-800 transition-colors"
            >
              Copiar link de la oferta
            </button>
          </div>
        </div>
      </div>
    ) : (
      <div>
        <!-- Toolbar: filtro + sort -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
          <div class="flex items-center gap-3 flex-wrap">
            <p class="text-sm text-gray-500">
              <span id="visible-count" class="font-semibold text-gray-900">{total}</span>
              <span id="visible-label">candidato{total !== 1 ? 's' : ''}</span>
            </p>
            <div class="relative">
              <svg class="w-3.5 h-3.5 text-gray-400 absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input
                type="search"
                id="filter-kw"
                placeholder="Filtrar por skill…"
                autocomplete="off"
                class="text-xs border border-gray-200 rounded-lg pl-8 pr-3 py-1.5 w-44 sm:w-52 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent placeholder:text-gray-400"
              />
            </div>
          </div>
          <div class="flex items-center gap-1.5 flex-wrap">
            <span class="text-xs text-gray-400 mr-1">Ordenar:</span>
            <button id="sort-match" class="sort-btn text-xs px-2.5 py-1 rounded-lg border border-brand-200 bg-brand-50 text-brand-700 font-medium transition-colors">
              Mejor match
            </button>
            <button id="sort-fecha" class="sort-btn text-xs px-2.5 py-1 rounded-lg border border-gray-200 text-gray-500 font-medium hover:bg-gray-50 transition-colors">
              Más reciente
            </button>
            <button id="sort-nombre" class="sort-btn text-xs px-2.5 py-1 rounded-lg border border-gray-200 text-gray-500 font-medium hover:bg-gray-50 transition-colors">
              A-Z
            </button>
          </div>
        </div>
        <p id="filter-empty" class="hidden text-center text-sm text-gray-500 py-10 bg-white border border-gray-200 rounded-2xl mb-3">
          Ningún candidato coincide con ese filtro.
        </p>
        <div id="candidates-list" class="space-y-3">
        {postulaciones.map((p, i) => {
          const cv = p.cv_parsed as {
            nombre_completo?: string | null;
            telefono?: string | null;
            titulo_profesional?: string | null;
            resumen?: string | null;
            skills_tecnicas?: string[];
            skills_blandas?: string[];
            keywords?: string[];
            anos_experiencia?: number | null;
            ubicacion?: string | null;
            idiomas?: Array<{ idioma: string; nivel: string | null }>;
            experiencia?: Array<{ empresa: string | null; cargo: string | null }>;
            parse_method?: string;
            used_ocr?: boolean;
            ocr_engine?: string | null;
          } | null;
          const displayName = p.nombre || cv?.nombre_completo || null;
          // Preferir keywords canónicas; fallback legacy palabras_clave
          const keywords = (p.keywords?.length ? p.keywords : p.palabras_clave) ?? [];
          // Chips: unir skills técnicas + keywords (sin duplicados, case-insensitive)
          const techTags: string[] = (() => {
            const seen = new Set<string>();
            const out: string[] = [];
            for (const t of [...(cv?.skills_tecnicas ?? []), ...keywords]) {
              const k = t.trim();
              if (!k) continue;
              const n = k.toLowerCase();
              if (seen.has(n)) continue;
              seen.add(n);
              out.push(k);
            }
            return out;
          })();
          const hasKeywords = techTags.length > 0 || (cv?.skills_blandas?.length ?? 0) > 0;
          const showResumen = Boolean(cv?.resumen);
          const initials = (displayName || '?')
            .split(' ')
            .slice(0, 2)
            .map((w: string) => w[0] || '')
            .join('')
            .toUpperCase()
            .slice(0, 2);
          const colors = [
            'bg-brand-100 text-brand-700',
            'bg-indigo-100 text-indigo-700',
            'bg-emerald-100 text-emerald-700',
            'bg-amber-100 text-amber-700',
            'bg-rose-100 text-rose-700',
          ];
          const color = colors[i % colors.length];
          const animDelay = 'animation-delay: ' + (i * 60) + 'ms';
          const score = p.match_score as number | null;
          const parseOk = p.parse_status === 'success';
          const parsePending = p.parse_status === 'pending';
          return (
            <div
              class="card-anim candidate-row bg-white border border-slate-200/90 rounded-2xl p-5 shadow-soft hover:border-brand-300 hover:shadow-card-hover hover:-translate-y-0.5 transition-all ring-1 ring-slate-900/[0.03]"
              style={animDelay}
              data-nombre={displayName || ''}
              data-email={p.email || ''}
              data-fecha={p.created_at}
              data-match={score != null ? String(score) : '-1'}
              data-keywords={[...keywords, ...(cv?.skills_tecnicas || []), ...(cv?.skills_blandas || []), cv?.titulo_profesional || '', displayName || ''].join(' ').toLowerCase()}
            >
              <div class="flex items-start gap-4">
                <!-- Avatar con badge numérico -->
                <div class="relative shrink-0">
                  <div class={`w-11 h-11 rounded-xl flex items-center justify-center font-bold text-sm ${color}`}>
                    {initials}
                  </div>
                  <span class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-gray-800 text-white text-[10px] font-bold rounded-full flex items-center justify-center leading-none">
                    {i + 1}
                  </span>
                </div>

                <!-- Info principal -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-3 flex-wrap">
                    <div>
                      <div class="flex items-center gap-2 flex-wrap">
                        <p class="font-semibold text-gray-900">
                          {displayName || <span class="text-gray-400 italic font-normal">Anónimo</span>}
                        </p>
                        {score != null && (
                          <span
                            class={`inline-flex items-center gap-1 text-[11px] font-bold px-2 py-0.5 rounded-full border ${scoreClasses(score)}`}
                            title="Afinidad estimada según skills del CV vs. la oferta (heurística, no es IA perfecta)"
                          >
                            {score}% match
                          </span>
                        )}
                        {parsePending && (
                          <span class="text-[11px] text-amber-600 bg-amber-50 border border-amber-100 px-2 py-0.5 rounded-full">
                            Analizando CV…
                          </span>
                        )}
                        {p.parse_status === 'failed' && (
                          <span class="text-[11px] text-gray-500 bg-gray-50 border border-gray-200 px-2 py-0.5 rounded-full" title="El CV se guardó; el análisis automático no pudo completarse">
                            Sin análisis
                          </span>
                        )}
                        {cv?.used_ocr && (
                          <span
                            class="text-[11px] text-violet-700 bg-violet-50 border border-violet-100 px-2 py-0.5 rounded-full"
                            title={cv.ocr_engine ? `OCR: ${cv.ocr_engine}` : 'Texto extraído por OCR (PDF escaneado)'}
                          >
                            OCR
                          </span>
                        )}
                      </div>
                      {cv?.titulo_profesional && (
                        <p class="text-sm text-gray-600 mt-0.5 font-medium">{cv.titulo_profesional}</p>
                      )}
                      <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-1 text-sm text-gray-500">
                        {p.email ? (
                          <span class="inline-flex items-center gap-1">
                            <a href={`mailto:${p.email}`} class="text-brand-600 hover:underline">
                              {p.email}
                            </a>
                            <button
                              class="copy-email-btn text-gray-300 hover:text-gray-500 transition-colors p-0.5 rounded"
                              data-email={p.email}
                              title="Copiar email"
                            >
                              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                              </svg>
                            </button>
                          </span>
                        ) : (
                          <span class="text-gray-400">Sin email</span>
                        )}
                        {cv?.telefono && <span>· {cv.telefono}</span>}
                        {cv?.ubicacion && <span>· 📍 {cv.ubicacion}</span>}
                        {cv?.anos_experiencia != null && (
                          <span>· {cv.anos_experiencia} año{cv.anos_experiencia === 1 ? '' : 's'} exp.</span>
                        )}
                      </div>
                    </div>
                    <div class="flex items-center gap-3 shrink-0">
                      <span
                        class="relative-time text-xs text-gray-400 whitespace-nowrap"
                        data-time={p.created_at}
                        title={new Date(p.created_at).toLocaleDateString('es-CL', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' })}
                      >
                        {new Date(p.created_at).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' })}
                      </span>
                      <a
                        href={`/api/postulaciones/cv?id=${p.id}`}
                        target="_blank"
                        class="inline-flex items-center gap-1.5 bg-brand-600 text-white text-xs font-semibold px-3 py-1.5 rounded-lg hover:bg-brand-700 transition-colors shadow-sm"
                      >
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Descargar CV
                      </a>
                    </div>
                  </div>

                  <!-- Resumen del CV (desde cv_parsed) -->
                  {showResumen && (
                    <p class="mt-3 text-sm text-gray-600 leading-relaxed line-clamp-3 bg-gray-50 border border-gray-100 rounded-xl px-3 py-2">
                      {cv!.resumen}
                    </p>
                  )}

                  <!-- Últimas experiencias (compacto) -->
                  {cv?.experiencia && cv.experiencia.length > 0 && (
                    <div class="mt-2.5 flex flex-wrap gap-1.5">
                      {cv.experiencia.slice(0, 3).map((exp) => (
                        <span class="text-[11px] text-gray-600 bg-white border border-gray-200 px-2 py-0.5 rounded-lg">
                          {[exp.cargo, exp.empresa].filter(Boolean).join(' · ') || 'Experiencia'}
                        </span>
                      ))}
                    </div>
                  )}

                  <!-- Keywords / skills como chips -->
                  {hasKeywords ? (
                    <>
                      {techTags.length > 0 && (
                        <div class="flex flex-wrap gap-1.5 mt-3" aria-label="Palabras clave del CV">
                          {techTags.slice(0, 14).map((k: string) => (
                            <span class="text-xs bg-indigo-50 text-indigo-700 border border-indigo-100 px-2 py-0.5 rounded-full font-medium">
                              {k}
                            </span>
                          ))}
                          {techTags.length > 14 && (
                            <span class="text-xs text-gray-400 px-1 py-0.5">+{techTags.length - 14} más</span>
                          )}
                        </div>
                      )}
                      {cv?.skills_blandas && cv.skills_blandas.length > 0 && (
                        <div class="flex flex-wrap gap-1.5 mt-1.5" aria-label="Skills blandas">
                          {cv.skills_blandas.slice(0, 6).map((k: string) => (
                            <span class="text-xs bg-emerald-50 text-emerald-700 border border-emerald-100 px-2 py-0.5 rounded-full">
                              {k}
                            </span>
                          ))}
                        </div>
                      )}
                    </>
                  ) : (
                    !parsePending && (
                      <p class="mt-3 text-xs text-gray-400 italic">
                        {p.parse_status === 'failed' || p.parse_status === 'skipped'
                          ? 'No se pudieron extraer palabras clave de este CV.'
                          : parseOk
                            ? 'Sin palabras clave detectadas.'
                            : ''}
                      </p>
                    )
                  )}
                </div>
              </div>
            </div>
          );
        })}

          <!-- Footer con total -->
          <p class="text-center text-xs text-gray-400 pt-2">
            Mostrando {total} postulaci{total === 1 ? 'ón' : 'ones'} · Los CVs se eliminan automáticamente a los 90 días
          </p>
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    // Copiar link (empty state)
    const btnCopyEmpty = document.getElementById('btn-copy-offer-empty');
    btnCopyEmpty?.addEventListener('click', async () => {
      const path = btnCopyEmpty.getAttribute('data-url') || '';
      const url = path.startsWith('http') ? path : window.location.origin + path;
      try {
        await navigator.clipboard.writeText(url);
        const prev = btnCopyEmpty.textContent;
        btnCopyEmpty.textContent = '¡Link copiado!';
        setTimeout(() => { if (prev) btnCopyEmpty.textContent = prev; }, 2000);
      } catch {}
    });

    // Tiempos relativos
    document.querySelectorAll<HTMLElement>('.relative-time').forEach(el => {
      const iso = el.dataset.time;
      if (!iso) return;
      const diff = Date.now() - new Date(iso).getTime();
      const mins = Math.floor(diff / 60000);
      const hours = Math.floor(diff / 3600000);
      const days = Math.floor(diff / 86400000);
      if (mins < 1) el.textContent = 'Ahora';
      else if (mins < 60) el.textContent = `hace ${mins} min`;
      else if (hours < 24) el.textContent = `hace ${hours} h`;
      else if (days === 1) el.textContent = 'ayer';
      else if (days < 30) el.textContent = `hace ${days} días`;
      else el.textContent = new Date(iso).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' });
    });

    // Copiar email individual
    document.querySelectorAll<HTMLButtonElement>('.copy-email-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const email = btn.dataset.email;
        if (!email) return;
        await navigator.clipboard.writeText(email).catch(() => {});
        const prev = btn.innerHTML;
        btn.innerHTML = '<svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(() => { btn.innerHTML = prev; }, 2000);
      });
    });

    // Copiar todos los emails
    const btnTodos = document.getElementById('btn-copiar-emails');
    const txtTodos = document.getElementById('copiar-emails-txt');
    btnTodos?.addEventListener('click', async () => {
      const emails = btnTodos.dataset.emails;
      if (!emails) return;
      await navigator.clipboard.writeText(emails).catch(() => {});
      if (txtTodos) {
        const original = txtTodos.textContent;
        txtTodos.textContent = '¡Copiado!';
        setTimeout(() => { if (txtTodos) txtTodos.textContent = original; }, 2000);
      }
    });
  });
</script>

<script define:vars={{ csvRows, ofertaTitulo: oferta.titulo }}>
  document.addEventListener('astro:page-load', () => {
    // CSV export
    const btnCSV = document.getElementById('btn-export-csv');
    btnCSV?.addEventListener('click', () => {
      const header = ['Nombre', 'Email', 'Teléfono', 'Título', 'Años exp.', 'Ubicación', 'Match %', 'Fecha', 'Keywords'];
      const rows = csvRows.map((r) => [r.nombre, r.email, r.telefono, r.titulo, r.anos, r.ubicacion, r.match_score, r.fecha, r.keywords]);
      const csv = [header, ...rows]
        .map(row => row.map(v => `"${String(v).replace(/"/g, '""')}"`).join(','))
        .join('\n');
      const a = document.createElement('a');
      a.href = 'data:text/csv;charset=utf-8,\uFEFF' + encodeURIComponent(csv);
      a.download = `postulaciones-${ofertaTitulo.replace(/[^a-z0-9]/gi, '-').toLowerCase()}.csv`;
      a.click();
    });

    // Sort candidates
    const list = document.getElementById('candidates-list');
    const btnFecha = document.getElementById('sort-fecha');
    const btnNombre = document.getElementById('sort-nombre');
    const btnMatch = document.getElementById('sort-match');
    const sortBtns = [btnFecha, btnNombre, btnMatch];

    function setActive(active: HTMLElement | null) {
      sortBtns.forEach((b) => {
        if (!b) return;
        const on = b === active;
        b.classList.toggle('bg-brand-50', on);
        b.classList.toggle('text-brand-700', on);
        b.classList.toggle('border-brand-200', on);
        b.classList.toggle('text-gray-500', !on);
        b.classList.toggle('border-gray-200', !on);
      });
    }

    function sortCards(by: 'fecha' | 'nombre' | 'match') {
      if (!list) return;
      const cards = Array.from(list.querySelectorAll<HTMLElement>('.candidate-row'));
      cards.sort((a, b) => {
        if (by === 'nombre') {
          return (a.dataset.nombre || '').localeCompare(b.dataset.nombre || '', 'es', { sensitivity: 'base' });
        }
        if (by === 'match') {
          return Number(b.dataset.match || -1) - Number(a.dataset.match || -1);
        }
        return new Date(b.dataset.fecha || 0).getTime() - new Date(a.dataset.fecha || 0).getTime();
      });
      cards.forEach(c => list.appendChild(c));
      setActive(by === 'fecha' ? btnFecha : by === 'match' ? btnMatch : btnNombre);
    }

    // Filtro por keyword / skill
    const filterInput = document.getElementById('filter-kw') as HTMLInputElement | null;
    const filterEmpty = document.getElementById('filter-empty');
    const visibleCount = document.getElementById('visible-count');
    const visibleLabel = document.getElementById('visible-label');

    function applyFilter() {
      if (!list) return;
      const q = (filterInput?.value || '').trim().toLowerCase().normalize('NFD').replace(/\p{Mn}/gu, '');
      const cards = Array.from(list.querySelectorAll<HTMLElement>('.candidate-row'));
      let shown = 0;
      cards.forEach((card) => {
        const hay = (card.dataset.keywords || '').normalize('NFD').replace(/\p{Mn}/gu, '');
        const ok = !q || hay.includes(q);
        card.style.display = ok ? '' : 'none';
        if (ok) shown++;
      });
      if (visibleCount) visibleCount.textContent = String(shown);
      if (visibleLabel) visibleLabel.textContent = shown === 1 ? 'candidato' : 'candidatos';
      if (filterEmpty) filterEmpty.classList.toggle('hidden', shown > 0 || !q);
    }

    filterInput?.addEventListener('input', applyFilter);

    btnFecha?.addEventListener('click', () => sortCards('fecha'));
    btnNombre?.addEventListener('click', () => sortCards('nombre'));
    btnMatch?.addEventListener('click', () => sortCards('match'));

    // Default ya es match (servidor); re-aplicar para estado de botones
    setActive(btnMatch);
  });
</script>

