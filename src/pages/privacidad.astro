---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Política de privacidad">
  <section class="mx-auto max-w-3xl space-y-4 rounded-xl border border-border bg-white p-6">
    <h2 class="text-2xl font-semibold text-text-primary">Política de privacidad</h2>
    <p class="text-sm text-text-secondary">
      Solo solicitamos lo esencial: tu CV y datos opcionales de contacto. No usamos tus datos para fines
      distintos a la postulación. Eliminamos postulaciones pasados 90 días.
    </p>
    <p class="text-sm text-text-secondary">
      Puedes escribir a soporte@miportal.cl para solicitar eliminación inmediata.
    </p>
  </section>
</Layout>
