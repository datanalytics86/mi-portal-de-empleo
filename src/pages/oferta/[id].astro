---
import Layout from '../../layouts/Layout.astro';
import { createServiceClient } from '../../lib/supabase';
import { TIPOS } from '../../lib/constants';

const { id } = Astro.params;

// Usa service role para leer sin restricciones RLS y poder distinguir
// "no existe" de "expirada" (la policy pública filtra activa+expira_en)
const { data: ofertaRaw, error } = id
  ? await createServiceClient().from('ofertas').select('*').eq('id', id).single()
  : { data: null, error: true };

const isExpired = ofertaRaw && (!ofertaRaw.activa || ofertaRaw.expira_en < new Date().toISOString());
const notFound = !ofertaRaw || !!error;

if (notFound) Astro.response.status = 404;
if (isExpired) Astro.response.status = 410;

// Solo continúa al renderizado normal si la oferta es válida
const oferta = !notFound && !isExpired ? ofertaRaw : null;

const exito = Astro.url.searchParams.get('exito') === '1';

// JSON-LD JobPosting para Google Jobs
const SCHEMA_TIPOS: Record<string, string> = {
  'full-time': 'FULL_TIME',
  'part-time': 'PART_TIME',
  'freelance': 'CONTRACTOR',
  'practica': 'INTERN',
};

const jsonLd = oferta ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: oferta.titulo,
  description: oferta.descripcion,
  datePosted: oferta.created_at.split('T')[0],
  validThrough: oferta.expira_en.split('T')[0],
  employmentType: SCHEMA_TIPOS[oferta.tipo_empleo] || 'OTHER',
  hiringOrganization: { '@type': 'Organization', name: oferta.empresa },
  jobLocation: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      addressLocality: oferta.comuna,
      addressCountry: 'CL',
    },
  },
  ...(oferta.categoria ? { occupationalCategory: oferta.categoria } : {}),
}) : null;

const ofertaDescription = oferta
  ? `${oferta.empresa} busca ${oferta.titulo} en ${oferta.comuna}, Chile. ${oferta.descripcion.slice(0, 140).replace(/\n/g, ' ').trim()}${oferta.descripcion.length > 140 ? '…' : ''} · Postula gratis sin registro.`
  : 'Oferta laboral en Chile. Postula con tu CV en segundos.';

const ofertaOgTitle = oferta
  ? `${oferta.titulo} — ${oferta.empresa} · ${oferta.comuna}`
  : 'Oferta no disponible';

// Barra de progreso del tiempo
const diasRestantes = oferta
  ? Math.max(0, Math.ceil((new Date(oferta.expira_en).getTime() - Date.now()) / (1000 * 60 * 60 * 24)))
  : 0;
const totalDias = oferta
  ? Math.max(1, Math.ceil((new Date(oferta.expira_en).getTime() - new Date(oferta.created_at).getTime()) / (1000 * 60 * 60 * 24)))
  : 1;
const pctTranscurrido = Math.min(100, Math.round(((totalDias - diasRestantes) / totalDias) * 100));
// Pre-computadas para evitar template literals anidados en expresiones Astro
const urgenciaTexto = diasRestantes <= 1 ? '⚡ Último día' : diasRestantes <= 5 ? ('⚡ Cierra en ' + diasRestantes + ' días') : (diasRestantes + ' días restantes');
const barraColor = 'h-full rounded-full transition-all ' + (diasRestantes <= 3 ? 'bg-red-400' : diasRestantes <= 7 ? 'bg-orange-300' : 'bg-white');
const barraWidth = 'width: ' + pctTranscurrido + '%';
// Tiempo estimado de lectura (~200 palabras/min)
const readingTime = oferta
  ? Math.max(1, Math.round(oferta.descripcion.split(/\s+/).filter(Boolean).length / 200))
  : 0;
---

{(notFound || isExpired) && (
  <Layout title="Oferta no disponible">
    <div class="max-w-lg mx-auto px-4 py-24 text-center">
      <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
        {isExpired ? (
          <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        ) : (
          <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        )}
      </div>
      {isExpired ? (
        <>
          <h1 class="text-2xl font-bold text-gray-900 mb-2">Esta oferta ya no está disponible</h1>
          <p class="text-gray-500 mb-8">El plazo de postulación venció o el empleador la desactivó.</p>
        </>
      ) : (
        <>
          <h1 class="text-2xl font-bold text-gray-900 mb-2">Oferta no encontrada</h1>
          <p class="text-gray-500 mb-8">El enlace puede estar desactualizado o la oferta fue eliminada.</p>
        </>
      )}
      <a
        href="/"
        class="inline-block bg-brand-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-brand-700 transition-colors shadow-sm"
      >
        Ver otras ofertas
      </a>
    </div>
  </Layout>
)}

{oferta && <Layout title={ofertaOgTitle} description={ofertaDescription} ogType="article" leaflet={true}>
  <script slot="head" type="application/ld+json" set:html={jsonLd} />
  <!-- Hero de la oferta -->
  <div class="relative overflow-hidden bg-gradient-to-br from-brand-800 via-brand-600 to-indigo-600 py-10 sm:py-12 px-4">
    <div class="pointer-events-none absolute inset-0 bg-hero-mesh opacity-80" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto">
      <div class="flex items-center justify-between mb-6 gap-2 flex-wrap">
        <a href="/" class="inline-flex items-center gap-1.5 text-brand-100 hover:text-white text-sm font-medium transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver a ofertas
        </a>
        <div class="flex items-center gap-2">
          <button
            id="btn-copiar-link"
            type="button"
            class="inline-flex items-center gap-1.5 text-brand-200 hover:text-white text-sm transition-colors bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg px-3 py-1.5 backdrop-blur"
            title="Copiar link de la oferta"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <span id="copy-link-txt">Copiar link</span>
          </button>
          <button
            id="btn-compartir"
            type="button"
            class="inline-flex items-center gap-1.5 text-brand-200 hover:text-white text-sm transition-colors bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg px-3 py-1.5 backdrop-blur"
            title="Compartir oferta"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
            <span id="share-txt">Compartir</span>
          </button>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="w-14 h-14 rounded-2xl bg-white/15 backdrop-blur flex items-center justify-center text-white font-bold text-xl shrink-0 border border-white/25 shadow-glow">
          {oferta.empresa.slice(0, 2).toUpperCase()}
        </div>
        <div>
          <h1 class="text-2xl sm:text-3xl font-extrabold text-white leading-tight tracking-tight">{oferta.titulo}</h1>
          <p class="text-brand-100 text-lg mt-1 font-medium">{oferta.empresa}</p>
          <div class="flex flex-wrap gap-2 mt-3">
            <span class="text-xs bg-white/20 text-white px-3 py-1 rounded-full font-medium border border-white/20 backdrop-blur">
              {TIPOS[oferta.tipo_empleo] || oferta.tipo_empleo}
            </span>
            <span class="text-xs bg-white/20 text-white px-3 py-1 rounded-full border border-white/20 backdrop-blur flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              {oferta.comuna}
            </span>
            {oferta.categoria && (
              <span class="text-xs bg-white/20 text-white px-3 py-1 rounded-full border border-white/20 backdrop-blur">
                {oferta.categoria}
              </span>
            )}
          </div>
          <p class="text-xs text-brand-200 mt-3">
            Publicada el {new Date(oferta.created_at).toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' })}
            &nbsp;·&nbsp; Vigente hasta {new Date(oferta.expira_en).toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <!-- Barra de progreso del tiempo restante -->
          <div class="mt-3 max-w-sm">
            <div class="flex items-center justify-between text-xs text-brand-200 mb-1.5">
              <span>Publicada</span>
              <span class={diasRestantes <= 1 ? 'text-red-300 font-semibold' : diasRestantes <= 5 ? 'text-orange-300 font-semibold' : ''}>
                {urgenciaTexto}
              </span>
            </div>
            <div class="bg-white/20 rounded-full h-1.5 overflow-hidden">
              <div
                class={barraColor}
                style={barraWidth}
              ></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Descripción -->
      <div class="bg-white border border-slate-200/90 rounded-2xl p-6 shadow-card ring-1 ring-slate-900/5">
        <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
          <div class="w-6 h-6 bg-brand-100 rounded-lg flex items-center justify-center">
            <svg class="w-3.5 h-3.5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          Descripción del cargo
          {readingTime > 0 && (
            <span class="ml-auto text-xs text-gray-400 font-normal flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              ~{readingTime} min
            </span>
          )}
        </h2>
        <div class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">
          {oferta.descripcion}
        </div>
      </div>

      <!-- Columna derecha: mapa + formulario -->
      <div class="space-y-6">
        <!-- Mini mapa -->
        {oferta.lat && oferta.lng && (
          <div class="bg-white border border-slate-200/90 rounded-2xl p-6 shadow-card ring-1 ring-slate-900/5">
            <h2 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
              <div class="w-6 h-6 bg-brand-100 rounded-lg flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
              </div>
              Ubicación
            </h2>
            <div id="mini-mapa" class="h-40 rounded-lg border border-gray-200 overflow-hidden"></div>
          </div>
        )}

        <!-- Formulario de postulación -->
        <div class="bg-white border border-slate-200/90 rounded-2xl p-6 shadow-card ring-1 ring-slate-900/5">
          <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
            <div class="w-6 h-6 bg-green-100 rounded-lg flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </div>
            Postular a esta oferta
          </h2>

          {exito ? (
            <div class="bg-green-50 border border-green-200 rounded-xl p-5 text-center">
              <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <p class="text-green-800 font-semibold">¡Postulación enviada!</p>
              <p class="text-sm text-green-700 mt-1">
                Recibimos tu CV. El empleador verá un resumen y keywords automáticamente.
              </p>
              <p class="text-xs text-green-600/80 mt-2">CV privado · se elimina a los 90 días</p>
              <a href="/" class="mt-4 inline-block text-sm text-brand-600 font-semibold hover:underline">Ver más ofertas →</a>
            </div>
          ) : (
            <form
              id="form-postulacion"
              action={`/api/postulaciones`}
              method="post"
              enctype="multipart/form-data"
              class="space-y-4"
            >
              <input type="hidden" name="oferta_id" value={oferta.id} />

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nombre <span class="text-gray-400 font-normal">(opcional)</span></label>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <input
                    type="text"
                    name="nombre"
                    placeholder="Tu nombre"
                    class="w-full border border-gray-300 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email <span class="text-gray-400 font-normal">(opcional)</span></label>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <input
                    type="email"
                    name="email"
                    placeholder="tu@email.com"
                    class="w-full border border-gray-300 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                  CV <span class="text-red-500">*</span>
                  <span class="text-gray-400 font-normal">&nbsp;PDF o Word, máx. 5MB</span>
                </label>
                <!-- Drop zone -->
                <div
                  id="cv-dropzone"
                  class="border-2 border-dashed border-gray-200 rounded-xl p-4 hover:border-brand-300 transition-colors cursor-pointer bg-gray-50/50"
                >
                  <input
                    type="file"
                    name="cv"
                    id="cv-input"
                    accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
                    required
                    class="sr-only"
                  />
                  <div id="cv-placeholder" class="text-center py-2">
                    <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                    </svg>
                    <p class="text-sm text-gray-600 font-medium">Arrastra tu CV aquí</p>
                    <p class="text-xs text-gray-400 mt-0.5">o toca para elegir · PDF / Word</p>
                  </div>
                  <div id="cv-preview" class="hidden flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-brand-50 text-brand-700 flex items-center justify-center shrink-0">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                      <p id="cv-name" class="text-sm font-medium text-gray-900 truncate"></p>
                      <p id="cv-size" class="text-xs text-gray-400"></p>
                    </div>
                    <button type="button" id="cv-clear" class="text-xs text-gray-400 hover:text-red-500 font-medium shrink-0 px-2 py-1">
                      Quitar
                    </button>
                  </div>
                </div>
                <p class="text-[11px] text-gray-400 mt-1.5">Máx. 3 postulaciones por hora · sin registro</p>
              </div>

              <div class="flex items-start gap-2.5">
                <input
                  type="checkbox"
                  id="privacidad"
                  name="privacidad"
                  required
                  class="mt-0.5 h-4 w-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500"
                />
                <label for="privacidad" class="text-xs text-gray-500 leading-relaxed">
                  Acepto que mis datos y CV sean tratados para esta postulación y eliminados a los 90 días.
                </label>
              </div>

              <div id="error-msg" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-xl p-3 flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span></span>
              </div>

              <button
                type="submit"
                id="btn-postular"
                class="w-full bg-brand-600 text-white py-3 rounded-xl font-semibold hover:bg-brand-700 transition-colors disabled:opacity-60 shadow-sm text-sm"
              >
                Enviar postulación
              </button>
            </form>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Sticky CTA móvil: visible en sm y abajo, se oculta cuando el form es visible -->
  {!exito && (
    <div
      id="sticky-cta"
      class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-white border-t border-gray-200 px-4 py-3 shadow-2xl translate-y-0 transition-transform duration-300"
    >
      <button
        type="button"
        id="sticky-btn"
        class="w-full bg-brand-600 text-white py-3 rounded-xl font-semibold text-sm hover:bg-brand-700 transition-colors shadow-sm"
      >
        Postular a esta oferta
      </button>
    </div>
  )}
</Layout>}

<script define:vars={{ ofertaLat: oferta?.lat ?? null, ofertaLng: oferta?.lng ?? null, ofertaTitulo: oferta?.titulo ?? '', ofertaEmpresa: oferta?.empresa ?? '' }}>
  document.addEventListener('DOMContentLoaded', () => {
    // Confetti si la postulación fue enviada con éxito
    if (window.location.search.includes('exito=1')) {
      (function launchConfetti() {
        const canvas = document.createElement('canvas');
        canvas.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:9999';
        document.body.appendChild(canvas);
        const ctx = canvas.getContext('2d');
        if (!ctx) { canvas.remove(); return; }
        canvas.width = innerWidth; canvas.height = innerHeight;
        const colors = ['#4f46e5','#10b981','#f59e0b','#ef4444','#8b5cf6','#f97316','#06b6d4'];
        const pieces = Array.from({length: 110}, () => ({
          x: Math.random() * canvas.width,
          y: -10 - Math.random() * 80,
          vx: (Math.random() - 0.5) * 6,
          vy: Math.random() * 3 + 1.5,
          color: colors[Math.floor(Math.random() * colors.length)],
          w: Math.random() * 10 + 5,
          h: Math.random() * 5 + 3,
          rot: Math.random() * Math.PI * 2,
          drot: (Math.random() - 0.5) * 0.15,
        }));
        let f = 0;
        const draw = () => {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          pieces.forEach(p => {
            p.x += p.vx; p.y += p.vy; p.vy += 0.07; p.rot += p.drot;
            ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rot);
            ctx.fillStyle = p.color; ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
            ctx.restore();
          });
          if (++f < 200) requestAnimationFrame(draw); else canvas.remove();
        };
        requestAnimationFrame(draw);
      })();
    }

    // Sticky CTA móvil: scroll suave al form, se oculta cuando el form es visible
    const stickyCta = document.getElementById('sticky-cta');
    const stickyBtn = document.getElementById('sticky-btn');
    const formPostulacion = document.getElementById('form-postulacion');

    stickyBtn?.addEventListener('click', () => {
      formPostulacion?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    if (stickyCta && formPostulacion) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          stickyCta.style.transform = entry.isIntersecting ? 'translateY(100%)' : 'translateY(0)';
        },
        { threshold: 0.2 }
      );
      observer.observe(formPostulacion);
    }

    // Compartir / copiar link
    const btnCompartir = document.getElementById('btn-compartir');
    const shareTxt = document.getElementById('share-txt');
    const btnCopiarLink = document.getElementById('btn-copiar-link');
    const copyLinkTxt = document.getElementById('copy-link-txt');

    btnCopiarLink?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        if (copyLinkTxt) {
          copyLinkTxt.textContent = '¡Copiado!';
          setTimeout(() => { if (copyLinkTxt) copyLinkTxt.textContent = 'Copiar link'; }, 2000);
        }
      } catch {}
    });

    btnCompartir?.addEventListener('click', async () => {
      const url = window.location.href;
      try {
        if (navigator.share) {
          await navigator.share({ title: ofertaTitulo, text: `${ofertaTitulo} — ${ofertaEmpresa}`, url });
        } else {
          await navigator.clipboard.writeText(url);
          if (shareTxt) { shareTxt.textContent = '¡Copiado!'; setTimeout(() => { shareTxt.textContent = 'Compartir'; }, 2000); }
        }
      } catch {}
    });

    // Mini mapa
    const miniMapaEl = document.getElementById('mini-mapa');
    if (miniMapaEl && ofertaLat && ofertaLng) {
      const miniMap = L.map('mini-mapa', { zoomControl: true, dragging: false }).setView([ofertaLat, ofertaLng], 14);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap',
        maxZoom: 18,
      }).addTo(miniMap);
      L.marker([ofertaLat, ofertaLng]).addTo(miniMap).bindPopup(ofertaTitulo).openPopup();
    }

    // ── CV dropzone + validación cliente ──
    const MAX_CV = 5 * 1024 * 1024;
    const ALLOWED_EXT = ['.pdf', '.doc', '.docx'];
    const ALLOWED_MIME = [
      'application/pdf',
      'application/msword',
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
    ];

    const form = document.getElementById('form-postulacion') as HTMLFormElement | null;
    const btn = document.getElementById('btn-postular');
    const errorMsg = document.getElementById('error-msg');
    const cvInput = document.getElementById('cv-input') as HTMLInputElement | null;
    const dropzone = document.getElementById('cv-dropzone');
    const cvPlaceholder = document.getElementById('cv-placeholder');
    const cvPreview = document.getElementById('cv-preview');
    const cvName = document.getElementById('cv-name');
    const cvSize = document.getElementById('cv-size');
    const cvClear = document.getElementById('cv-clear');

    function showError(msg: string) {
      const span = errorMsg?.querySelector('span');
      if (span) span.textContent = msg;
      if (errorMsg) errorMsg.classList.remove('hidden');
    }
    function hideError() {
      if (errorMsg) errorMsg.classList.add('hidden');
    }

    function validateCvFile(file: File): string | null {
      if (!file || file.size === 0) return 'Debes adjuntar tu CV.';
      if (file.size > MAX_CV) return 'El archivo supera los 5MB.';
      const name = file.name.toLowerCase();
      const okExt = ALLOWED_EXT.some((e) => name.endsWith(e));
      const okMime = !file.type || ALLOWED_MIME.includes(file.type) || file.type === 'application/octet-stream';
      if (!okExt && !okMime) return 'Solo se aceptan PDF o Word (.pdf, .docx, .doc).';
      if (!okExt) return 'La extensión del archivo debe ser .pdf, .docx o .doc.';
      return null;
    }

    function formatSize(bytes: number): string {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function setCvFile(file: File | null) {
      if (!cvInput) return;
      if (!file) {
        cvInput.value = '';
        cvPlaceholder?.classList.remove('hidden');
        cvPreview?.classList.add('hidden');
        dropzone?.classList.remove('border-brand-400', 'bg-brand-50/40');
        return;
      }
      const err = validateCvFile(file);
      if (err) {
        showError(err);
        setCvFile(null);
        return;
      }
      hideError();
      // Asignar al input via DataTransfer
      try {
        const dt = new DataTransfer();
        dt.items.add(file);
        cvInput.files = dt.files;
      } catch {
        /* algunos browsers antiguos no soportan DataTransfer; el input change maneja */
      }
      if (cvName) cvName.textContent = file.name;
      if (cvSize) cvSize.textContent = formatSize(file.size);
      cvPlaceholder?.classList.add('hidden');
      cvPreview?.classList.remove('hidden');
      dropzone?.classList.add('border-brand-400', 'bg-brand-50/40');
    }

    dropzone?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('#cv-clear')) return;
      cvInput?.click();
    });

    cvInput?.addEventListener('change', () => {
      const f = cvInput.files?.[0] || null;
      if (f) setCvFile(f);
    });

    cvClear?.addEventListener('click', (e) => {
      e.stopPropagation();
      setCvFile(null);
    });

    ['dragenter', 'dragover'].forEach((ev) => {
      dropzone?.addEventListener(ev, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.add('border-brand-500', 'bg-brand-50');
      });
    });
    ['dragleave', 'drop'].forEach((ev) => {
      dropzone?.addEventListener(ev, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.remove('border-brand-500', 'bg-brand-50');
      });
    });
    dropzone?.addEventListener('drop', (e) => {
      const de = e as DragEvent;
      const f = de.dataTransfer?.files?.[0];
      if (f) setCvFile(f);
    });

    // Formulario con feedback (parse es async en servidor → respuesta rápida)
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        hideError();

        const cv = cvInput?.files?.[0];
        const clientErr = validateCvFile(cv as File);
        if (clientErr) {
          showError(clientErr);
          return;
        }

        if (btn) { btn.textContent = 'Enviando…'; btn.setAttribute('disabled', ''); }

        try {
          const formData = new FormData(form);
          const res = await fetch('/api/postulaciones', { method: 'POST', body: formData });
          const data = await res.json();
          if (res.ok && data.ok) {
            if (btn) btn.textContent = '¡Listo!';
            window.location.href = window.location.pathname + '?exito=1';
          } else {
            showError(data.error || 'Error al enviar. Intenta de nuevo.');
            if (btn) { btn.textContent = 'Enviar postulación'; btn.removeAttribute('disabled'); }
          }
        } catch {
          showError('Error de conexión. Intenta de nuevo.');
          if (btn) { btn.textContent = 'Enviar postulación'; btn.removeAttribute('disabled'); }
        }
      });
    }
  });
</script>
