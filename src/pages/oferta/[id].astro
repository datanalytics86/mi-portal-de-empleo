---
import Layout from '@/layouts/Layout.astro';
import FormularioPostulacion from '@/components/FormularioPostulacion.astro';
import { supabase } from '@/lib/supabase';
import { formatLongDate, formatRelativeTime } from '@/lib/utils/formatting';
import { getComunaByName } from '@/lib/comunas';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

// Obtener oferta
const { data: oferta, error } = await supabase
  .from('ofertas')
  .select('*')
  .eq('id', id)
  .single();

if (error || !oferta) {
  return Astro.redirect('/404');
}

// Verificar que la oferta esté activa
if (!oferta.activa || new Date(oferta.expires_at) < new Date()) {
  // Mostrar mensaje de oferta cerrada pero no redirigir
}

// Obtener coordenadas de la comuna
const comuna = getComunaByName(oferta.comuna);
const lat = comuna?.lat || -33.4489;
const lng = comuna?.lng || -70.6693;

// Calcular días hasta expiración
const diasHastaExpiracion = Math.ceil(
  (new Date(oferta.expires_at).getTime() - Date.now()) / (1000 * 60 * 60 * 24)
);
---

<Layout
  title={`${oferta.titulo} - ${oferta.empresa} | Portal de Empleo Chile`}
  description={oferta.descripcion.substring(0, 155) + '...'}
>
  <!-- Breadcrumb -->
  <nav class="container-custom py-4 text-sm" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-text-secondary">
      <li>
        <a href="/" class="hover:text-accent transition">Inicio</a>
      </li>
      <li aria-hidden="true">/</li>
      <li>
        <a href="/" class="hover:text-accent transition">Ofertas</a>
      </li>
      <li aria-hidden="true">/</li>
      <li class="text-text-primary" aria-current="page">{oferta.titulo}</li>
    </ol>
  </nav>

  <div class="container-custom py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Contenido Principal -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Header de la Oferta -->
        <div class="card">
          <div class="flex items-start justify-between gap-4 mb-6">
            <div>
              <h1 class="text-3xl md:text-4xl font-bold text-text-primary mb-2">
                {oferta.titulo}
              </h1>
              <p class="text-xl text-text-secondary">{oferta.empresa}</p>
            </div>
            {
              oferta.activa && diasHastaExpiracion > 0 ? (
                <span class="badge badge-green shrink-0">Activa</span>
              ) : (
                <span class="badge badge-red shrink-0">Cerrada</span>
              )
            }
          </div>

          <!-- Metadatos -->
          <div class="flex flex-wrap items-center gap-4 pb-6 border-b border-border">
            <div class="flex items-center gap-2 text-text-secondary">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span>{oferta.comuna}</span>
            </div>

            <div class="flex items-center gap-2">
              <span class="badge badge-blue">{oferta.tipo_jornada}</span>
            </div>

            {
              oferta.categoria && (
                <div class="flex items-center gap-2">
                  <span class="badge badge-yellow">{oferta.categoria}</span>
                </div>
              )
            }
          </div>

          <!-- Información Adicional -->
          <div class="grid grid-cols-2 gap-4 pt-6">
            <div>
              <p class="text-sm text-text-secondary mb-1">Publicado</p>
              <p class="font-medium text-text-primary">
                {formatRelativeTime(oferta.created_at)}
              </p>
              <p class="text-xs text-text-secondary mt-0.5">
                {formatLongDate(oferta.created_at)}
              </p>
            </div>
            <div>
              <p class="text-sm text-text-secondary mb-1">Válido hasta</p>
              <p class="font-medium text-text-primary">
                {formatLongDate(oferta.expires_at)}
              </p>
              {
                diasHastaExpiracion > 0 ? (
                  <p class="text-xs text-success mt-0.5">
                    {diasHastaExpiracion} día{diasHastaExpiracion !== 1 ? 's' : ''} restante
                    {diasHastaExpiracion !== 1 ? 's' : ''}
                  </p>
                ) : (
                  <p class="text-xs text-error mt-0.5">Expirada</p>
                )
              }
            </div>
          </div>
        </div>

        <!-- Descripción de la Oferta -->
        <div class="card">
          <h2 class="text-2xl font-semibold text-text-primary mb-4">Descripción del puesto</h2>
          <div class="prose prose-slate max-w-none">
            <p class="whitespace-pre-wrap text-text-secondary leading-relaxed">
              {oferta.descripcion}
            </p>
          </div>
        </div>

        <!-- Mapa de Ubicación -->
        <div class="card">
          <h2 class="text-2xl font-semibold text-text-primary mb-4">Ubicación</h2>
          <p class="text-text-secondary mb-4">
            <svg
              class="w-5 h-5 inline mr-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            {oferta.comuna}, Chile
          </p>
          <div
            id="mapa-oferta"
            class="h-[300px] rounded-lg border border-border"
            data-lat={lat}
            data-lng={lng}
            data-titulo={oferta.titulo}
          >
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="lg:sticky lg:top-24 space-y-6">
          {
            oferta.activa && diasHastaExpiracion > 0 ? (
              <FormularioPostulacion ofertaId={oferta.id} ofertaTitulo={oferta.titulo} />
            ) : (
              <div class="card bg-error/10 border-error">
                <div class="flex items-start gap-3">
                  <svg
                    class="w-6 h-6 text-error shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                  <div>
                    <h3 class="font-semibold text-error mb-1">Oferta cerrada</h3>
                    <p class="text-sm text-error/80">
                      Esta oferta ya no está aceptando postulaciones. Explora otras oportunidades en
                      nuestra plataforma.
                    </p>
                    <a href="/" class="btn btn-secondary btn-sm mt-4 w-full">
                      Ver todas las ofertas
                    </a>
                  </div>
                </div>
              </div>
            )
          }

          <!-- Info adicional -->
          <div class="card bg-surface">
            <h3 class="font-semibold text-text-primary mb-3">Sobre esta oferta</h3>
            <ul class="space-y-3 text-sm">
              <li class="flex items-start gap-2">
                <svg
                  class="w-5 h-5 text-accent shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-text-secondary">Postulación sin registro</span>
              </li>
              <li class="flex items-start gap-2">
                <svg
                  class="w-5 h-5 text-accent shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-text-secondary">Solo necesitas tu CV</span>
              </li>
              <li class="flex items-start gap-2">
                <svg
                  class="w-5 h-5 text-accent shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-text-secondary">Respuesta directa del empleador</span>
              </li>
              <li class="flex items-start gap-2">
                <svg
                  class="w-5 h-5 text-accent shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-text-secondary">Tus datos están protegidos</span>
              </li>
            </ul>
          </div>

          <!-- Botones de compartir -->
          <div class="card">
            <h3 class="font-semibold text-text-primary mb-3">Compartir oferta</h3>
            <div class="flex gap-2">
              <button
                class="btn btn-secondary flex-1 btn-sm"
                onclick="navigator.share ? navigator.share({title: document.title, url: window.location.href}) : alert('Función no disponible')"
                aria-label="Compartir oferta"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
                  ></path>
                </svg>
              </button>
              <button
                class="btn btn-secondary flex-1 btn-sm"
                onclick="navigator.clipboard.writeText(window.location.href).then(() => alert('¡Link copiado!'))"
                aria-label="Copiar link"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                  ></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Ofertas relacionadas (futuro) -->
  <!--
  <section class="container-custom py-16">
    <h2 class="text-2xl font-semibold text-text-primary mb-6">Ofertas similares</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      ...
    </div>
  </section>
  -->
</Layout>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  // Fix para iconos de Leaflet
  // @ts-ignore
  delete L.Icon.Default.prototype._getIconUrl;
  L.Icon.Default.mergeOptions({
    iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
    iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
    shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
  });

  // Inicializar mapa
  const mapaElement = document.getElementById('mapa-oferta');

  if (mapaElement) {
    const lat = parseFloat(mapaElement.getAttribute('data-lat') || '-33.4489');
    const lng = parseFloat(mapaElement.getAttribute('data-lng') || '-70.6693');
    const titulo = mapaElement.getAttribute('data-titulo') || '';

    const mapa = L.map('mapa-oferta').setView([lat, lng], 13);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(mapa);

    // Agregar marcador
    const marker = L.marker([lat, lng]).addTo(mapa);
    marker.bindPopup(`<div class="p-2"><strong>${titulo}</strong></div>`).openPopup();
  }
</script>
