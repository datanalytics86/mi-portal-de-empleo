---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { id } = Astro.params;

// Consultar sin filtrar activa/expira_en para distinguir "no existe" de "expirada"
const { data: ofertaRaw, error } = id
  ? await supabase.from('ofertas').select('*').eq('id', id).single()
  : { data: null, error: true };

const isExpired = ofertaRaw && (!ofertaRaw.activa || ofertaRaw.expira_en < new Date().toISOString());
const notFound = !ofertaRaw || !!error;

if (notFound) Astro.response.status = 404;
if (isExpired) Astro.response.status = 410;

// Solo continúa al renderizado normal si la oferta es válida
const oferta = !notFound && !isExpired ? ofertaRaw : null;

const TIPOS: Record<string, string> = {
  'full-time': 'Full-time',
  'part-time': 'Part-time',
  'freelance': 'Freelance',
  'practica': 'Práctica',
};

const exito = Astro.url.searchParams.get('exito') === '1';
---

{(notFound || isExpired) && (
  <Layout title="Oferta no disponible">
    <div class="max-w-lg mx-auto px-4 py-24 text-center">
      {isExpired ? (
        <>
          <p class="text-5xl mb-4">📋</p>
          <h1 class="text-2xl font-semibold text-gray-900 mb-2">Esta oferta ya no está disponible</h1>
          <p class="text-gray-500 mb-8">El plazo de postulación venció o el empleador la desactivó.</p>
        </>
      ) : (
        <>
          <p class="text-6xl font-bold text-brand-600 mb-4">404</p>
          <h1 class="text-2xl font-semibold text-gray-900 mb-2">Oferta no encontrada</h1>
          <p class="text-gray-500 mb-8">El enlace puede estar desactualizado o la oferta fue eliminada.</p>
        </>
      )}
      <a
        href="/"
        class="inline-block bg-brand-600 text-white px-6 py-2.5 rounded font-medium hover:bg-brand-700 transition-colors"
      >
        Ver otras ofertas
      </a>
    </div>
  </Layout>
)}

{oferta && <Layout title={oferta.titulo} leaflet={true}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <a href="/" class="text-sm text-brand-600 hover:underline mb-4 inline-block">← Volver a ofertas</a>

    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <!-- Cabecera -->
      <div class="p-6 border-b border-gray-100">
        <h1 class="text-2xl font-bold text-gray-900">{oferta.titulo}</h1>
        <p class="text-lg text-gray-600 mt-1">{oferta.empresa}</p>
        <div class="flex flex-wrap gap-2 mt-3">
          <span class="text-sm bg-brand-50 text-brand-700 px-3 py-1 rounded-full">
            {TIPOS[oferta.tipo_empleo] || oferta.tipo_empleo}
          </span>
          <span class="text-sm bg-gray-100 text-gray-700 px-3 py-1 rounded-full">
            {oferta.comuna}
          </span>
          {oferta.categoria && (
            <span class="text-sm bg-gray-100 text-gray-700 px-3 py-1 rounded-full">
              {oferta.categoria}
            </span>
          )}
        </div>
        <p class="text-xs text-gray-400 mt-3">
          Publicada el {new Date(oferta.created_at).toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' })}
          · Vigente hasta {new Date(oferta.expira_en).toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        <!-- Descripción -->
        <div class="p-6 border-b md:border-b-0 md:border-r border-gray-100">
          <h2 class="font-semibold text-gray-900 mb-3">Descripción del cargo</h2>
          <div class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">
            {oferta.descripcion}
          </div>
        </div>

        <!-- Columna derecha: mapa + formulario -->
        <div class="p-6 space-y-6">
          <!-- Mini mapa -->
          {oferta.lat && oferta.lng && (
            <div>
              <h2 class="font-semibold text-gray-900 mb-2">Ubicación</h2>
              <div id="mini-mapa" class="h-40 rounded border border-gray-200"></div>
            </div>
          )}

          <!-- Formulario de postulación -->
          <div>
            <h2 class="font-semibold text-gray-900 mb-3">Postular a esta oferta</h2>

            {exito ? (
              <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center">
                <p class="text-green-800 font-medium">¡Postulación enviada!</p>
                <p class="text-sm text-green-700 mt-1">Tu CV fue recibido correctamente.</p>
                <a href="/" class="mt-3 inline-block text-sm text-brand-600 hover:underline">Ver más ofertas</a>
              </div>
            ) : (
              <form
                id="form-postulacion"
                action={`/api/postulaciones`}
                method="post"
                enctype="multipart/form-data"
                class="space-y-3"
              >
                <input type="hidden" name="oferta_id" value={oferta.id} />

                <div>
                  <label class="block text-sm text-gray-700 mb-1">Nombre (opcional)</label>
                  <input
                    type="text"
                    name="nombre"
                    placeholder="Tu nombre"
                    class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                  />
                </div>

                <div>
                  <label class="block text-sm text-gray-700 mb-1">Email (opcional)</label>
                  <input
                    type="email"
                    name="email"
                    placeholder="tu@email.com"
                    class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                  />
                </div>

                <div>
                  <label class="block text-sm text-gray-700 mb-1">
                    CV <span class="text-red-500">*</span>
                    <span class="text-gray-400">(PDF o Word, máx. 5MB)</span>
                  </label>
                  <input
                    type="file"
                    name="cv"
                    accept=".pdf,.doc,.docx"
                    required
                    class="w-full text-sm text-gray-600 file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-sm file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100"
                  />
                </div>

                <div class="flex items-start gap-2">
                  <input
                    type="checkbox"
                    id="privacidad"
                    name="privacidad"
                    required
                    class="mt-0.5 h-4 w-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500"
                  />
                  <label for="privacidad" class="text-xs text-gray-600">
                    Acepto que mis datos y CV sean tratados para esta postulación y eliminados a los 90 días.
                  </label>
                </div>

                <div id="error-msg" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded p-2"></div>

                <button
                  type="submit"
                  id="btn-postular"
                  class="w-full bg-brand-600 text-white py-2.5 rounded font-medium hover:bg-brand-700 transition-colors disabled:opacity-60"
                >
                  Enviar postulación
                </button>
              </form>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>}

<script define:vars={{ ofertaLat: oferta?.lat ?? null, ofertaLng: oferta?.lng ?? null, ofertaTitulo: oferta?.titulo ?? '' }}>
  document.addEventListener('DOMContentLoaded', () => {
    // Mini mapa
    const miniMapaEl = document.getElementById('mini-mapa');
    if (miniMapaEl && ofertaLat && ofertaLng) {
      const miniMap = L.map('mini-mapa', { zoomControl: true, dragging: false }).setView([ofertaLat, ofertaLng], 14);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap',
        maxZoom: 18,
      }).addTo(miniMap);
      L.marker([ofertaLat, ofertaLng]).addTo(miniMap).bindPopup(ofertaTitulo).openPopup();
    }

    // Formulario con feedback
    const form = document.getElementById('form-postulacion');
    const btn = document.getElementById('btn-postular');
    const errorMsg = document.getElementById('error-msg');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (btn) { btn.textContent = 'Enviando...'; btn.setAttribute('disabled', ''); }
        if (errorMsg) errorMsg.classList.add('hidden');

        const formData = new FormData(form);
        const cv = formData.get('cv');
        if (!cv || !(cv instanceof File) || cv.size === 0) {
          if (errorMsg) { errorMsg.textContent = 'Debes adjuntar tu CV.'; errorMsg.classList.remove('hidden'); }
          if (btn) { btn.textContent = 'Enviar postulación'; btn.removeAttribute('disabled'); }
          return;
        }
        if (cv.size > 5 * 1024 * 1024) {
          if (errorMsg) { errorMsg.textContent = 'El archivo supera los 5MB.'; errorMsg.classList.remove('hidden'); }
          if (btn) { btn.textContent = 'Enviar postulación'; btn.removeAttribute('disabled'); }
          return;
        }

        try {
          const res = await fetch('/api/postulaciones', { method: 'POST', body: formData });
          const data = await res.json();
          if (res.ok && data.ok) {
            window.location.href = window.location.pathname + '?exito=1';
          } else {
            if (errorMsg) { errorMsg.textContent = data.error || 'Error al enviar. Intenta de nuevo.'; errorMsg.classList.remove('hidden'); }
            if (btn) { btn.textContent = 'Enviar postulación'; btn.removeAttribute('disabled'); }
          }
        } catch {
          if (errorMsg) { errorMsg.textContent = 'Error de conexión. Intenta de nuevo.'; errorMsg.classList.remove('hidden'); }
          if (btn) { btn.textContent = 'Enviar postulación'; btn.removeAttribute('disabled'); }
        }
      });
    }
  });
</script>
