---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  leaflet?: boolean;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = 'Portal de empleos en Chile. Postula con tu CV sin registro.',
  leaflet = false,
  ogImage,
  ogType = 'website',
} = Astro.props;
const fullTitle = title.includes('Portal de Empleos') ? title : `${title} | Portal de Empleos Chile`;
const canonicalUrl = new URL(Astro.url.pathname + Astro.url.search, Astro.site || Astro.url.origin).href;
const defaultOgImage = new URL('/favicon.svg', Astro.site || Astro.url.origin).href;
const resolvedOgImage = ogImage || defaultOgImage;
const ogDescription = description.length > 200 ? description.slice(0, 197) + '…' : description;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={ogDescription} />
    <meta name="theme-color" content="#4f46e5" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Portal de Empleos Chile" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {leaflet && (
      <>
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
      </>
    )}
    <slot name="head" />
    <ViewTransitions />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 font-sans antialiased">
    <!-- Header glass -->
    <header class="sticky top-0 z-40 border-b border-white/60 bg-white/80 backdrop-blur-xl shadow-soft">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="w-9 h-9 bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl flex items-center justify-center shadow-glow group-hover:scale-105 transition-transform">
            <svg class="w-4.5 h-4.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="leading-tight">
            <span class="block text-base font-bold text-slate-900 group-hover:text-brand-700 transition-colors tracking-tight">
              Empleos Chile
            </span>
            <span class="hidden sm:block text-[10px] font-medium text-slate-400 tracking-wide uppercase">
              Sin registro · Mapa · CV
            </span>
          </div>
        </a>
        <nav class="flex items-center gap-2 sm:gap-3 text-sm">
          <a
            href="/"
            class="text-slate-500 hover:text-slate-900 font-medium transition-colors px-3 py-1.5 rounded-lg hover:bg-slate-100"
          >
            Ofertas
          </a>
          <a
            href="/empleador/login"
            class="inline-flex items-center gap-1.5 bg-gradient-to-r from-brand-600 to-brand-700 text-white px-4 py-2 rounded-xl font-semibold hover:from-brand-700 hover:to-brand-800 transition-all shadow-soft hover:shadow-glow"
          >
            Para empleadores
          </a>
        </nav>
      </div>
    </header>

    <main class="min-h-[60vh]">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-20 border-t border-slate-200/80 bg-white">
      <div class="max-w-6xl mx-auto px-4 py-10">
        <div class="flex flex-col md:flex-row md:items-start justify-between gap-8">
          <div class="max-w-sm">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-7 h-7 bg-gradient-to-br from-brand-500 to-brand-700 rounded-lg flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <span class="text-sm font-bold text-slate-800">Empleos Chile</span>
            </div>
            <p class="text-sm text-slate-500 leading-relaxed">
              Portal minimalista de empleos. Postula con tu CV en segundos, sin crear cuenta.
              Los datos se eliminan a los 90 días.
            </p>
          </div>
          <div class="flex flex-wrap gap-x-10 gap-y-4 text-sm">
            <div>
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Candidatos</p>
              <a href="/" class="block text-slate-600 hover:text-brand-700 transition-colors mb-1.5">Ver ofertas</a>
              <p class="text-slate-400 text-xs">PDF o Word · máx. 5 MB</p>
            </div>
            <div>
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Empleadores</p>
              <a href="/empleador/login" class="block text-slate-600 hover:text-brand-700 transition-colors mb-1.5">Ingresar</a>
              <a href="/empleador/registro" class="block text-slate-600 hover:text-brand-700 transition-colors">Crear cuenta</a>
            </div>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-slate-100 flex flex-col sm:flex-row items-center justify-between gap-3">
          <p class="text-xs text-slate-400">
            &copy; {year} Portal de Empleos Chile
          </p>
          <a
            href="/empleador/login"
            class="text-xs font-semibold text-brand-600 hover:text-brand-800 transition-colors"
          >
            Publicar empleo gratis →
          </a>
        </div>
      </div>
    </footer>

    <button
      id="scroll-top"
      aria-label="Volver arriba"
      class="fixed bottom-20 md:bottom-6 right-5 z-40 w-11 h-11 bg-white text-brand-700 border border-brand-100 rounded-full shadow-card flex items-center justify-center opacity-0 pointer-events-none translate-y-2 transition-all duration-300 hover:bg-brand-600 hover:text-white hover:border-brand-600 hover:scale-105"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7" />
      </svg>
    </button>
  </body>
</html>

<script>
  document.addEventListener('keydown', (e) => {
    if (e.key !== '/' || e.ctrlKey || e.metaKey || e.altKey) return;
    const active = document.activeElement;
    if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.tagName === 'SELECT')) return;
    const searchInput = document.querySelector<HTMLInputElement>('input[name="q"]');
    if (!searchInput) return;
    e.preventDefault();
    searchInput.focus();
    searchInput.select();
  });

  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('scroll-top');
    if (!btn) return;
    const toggle = () => {
      const show = window.scrollY > 400;
      btn.classList.toggle('opacity-0', !show);
      btn.classList.toggle('pointer-events-none', !show);
      btn.classList.toggle('translate-y-2', !show);
    };
    window.addEventListener('scroll', toggle, { passive: true });
    btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  });
</script>

<style is:global>
  ::selection {
    background: #c7d2fe;
    color: #1e1b4b;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Focus agradable y accesible */
  :focus-visible {
    outline: 2px solid #6366f1;
    outline-offset: 2px;
  }

  button:not(:disabled),
  [type='submit']:not(:disabled),
  a.btn-primary {
    transition-property: transform, box-shadow, background-color, color, border-color, opacity;
    transition-duration: 160ms;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
  button:active:not(:disabled),
  [type='submit']:active:not(:disabled) {
    transform: scale(0.97);
  }

  /* Inputs más suaves en todo el sitio */
  input[type='text'],
  input[type='email'],
  input[type='password'],
  input[type='date'],
  input[type='search'],
  input[type='file'],
  select,
  textarea {
    transition: border-color 150ms ease, box-shadow 150ms ease, background-color 150ms ease;
  }

  /* Leaflet popup un poco más pro */
  .leaflet-popup-content-wrapper {
    border-radius: 12px !important;
    box-shadow: 0 8px 30px rgba(15, 23, 42, 0.12) !important;
    border: 1px solid #e2e8f0;
  }
  .leaflet-popup-tip {
    box-shadow: none !important;
  }
</style>
