---
interface Props {
  title: string;
  description?: string;
  leaflet?: boolean;
}

const { title, description = 'Portal de empleos en Chile', leaflet = false } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Portal de Empleos Chile</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {leaflet && (
      <>
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
      </>
    )}
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-40">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold text-brand-700 hover:text-brand-600">
          Empleos Chile
        </a>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/" class="text-gray-600 hover:text-gray-900">Ofertas</a>
          <a
            href="/empleador/login"
            class="bg-brand-600 text-white px-3 py-1.5 rounded hover:bg-brand-700 transition-colors"
          >
            Empleadores
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-16 border-t border-gray-200 bg-white">
      <div class="max-w-6xl mx-auto px-4 py-6 text-center text-sm text-gray-500">
        &copy; {new Date().getFullYear()} Portal de Empleos Chile. Los CVs y postulaciones se eliminan automáticamente a los 90 días.
      </div>
    </footer>
  </body>
</html>
