---
import '../styles/global.css';

const { title = 'Mi Portal de Empleo' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <header class="border-b border-border/80 bg-white/80 backdrop-blur">
      <div class="container-shell flex flex-col gap-4 py-6 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-text-secondary">Empleos Chile</p>
          <h1 class="text-2xl font-semibold text-text-primary">Mi portal de empleo</h1>
          <p class="mt-2 max-w-md text-sm text-text-secondary">
            Conecta talento y oportunidades en un flujo simple y directo.
          </p>
        </div>
        <nav class="text-sm text-text-secondary">
          <a
            class="inline-flex items-center gap-2 rounded-full border border-border bg-white px-4 py-2 text-sm font-medium text-text-primary transition hover:border-accent/50 hover:text-accent"
            href="/empleador/login"
          >
            Soy empleador
            <span aria-hidden="true">→</span>
          </a>
        </nav>
      </div>
    </header>

    <main class="container-shell py-12">
      <slot />
    </main>

    <footer class="border-t border-border bg-white">
      <div class="container-shell flex flex-col gap-2 py-6 text-sm text-text-secondary md:flex-row md:items-center md:justify-between">
        <span>Postula sin registro. Simple y directo.</span>
        <a class="hover:text-text-primary" href="/privacidad">Política de privacidad</a>
      </div>
    </footer>
  </body>
</html>
