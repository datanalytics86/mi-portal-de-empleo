---
import Button from './ui/Button.astro';
---
<header class="bg-white/80 backdrop-blur border-b border-slate-100 sticky top-0 z-20">
  <div class="container-max flex items-center justify-between py-4">
    <div class="flex items-center gap-3">
      <div class="h-10 w-10 rounded-2xl bg-brand-600 text-white flex items-center justify-center font-bold">ME</div>
      <div>
        <p class="text-sm uppercase tracking-wide text-brand-700 font-semibold">Mi Portal de Empleo</p>
        <p class="text-xs text-slate-500">Postula sin fricción · Geolocalizado</p>
      </div>
    </div>
    <div class="hidden md:flex items-center gap-3">
      <Button variant="secondary" href="#ofertas">Explorar ofertas</Button>
      <Button href="/empleador/oferta/nueva">Publicar empleo</Button>
    </div>
  </div>
</header>
