---
import Button from './ui/Button.astro';
---
<section class="bg-gradient-to-b from-brand-50/60 to-white border-b border-slate-100">
  <div class="container-max grid gap-10 py-12 md:grid-cols-2">
    <div class="space-y-6">
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-100 bg-white px-3 py-1 text-xs font-semibold text-brand-700 shadow-soft">
        Top LATAM · Sin registro · 100% móvil
      </div>
      <div class="space-y-4">
        <h1 class="text-3xl md:text-4xl font-bold leading-tight text-slate-900">
          Encuentra talento o tu próximo empleo en menos de 60 segundos.
        </h1>
        <p class="text-lg text-slate-600">
          Carga tu CV, postula y ve ofertas en el mapa. Para empleadores, publicar es tan simple como completar un formulario guiado.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <Button href="#postular">Subir CV ahora</Button>
        <Button variant="secondary" href="#mapa">Ver mapa interactivo</Button>
      </div>
      <div class="flex gap-4 text-sm text-slate-600">
        <div>
          <p class="text-xl font-bold text-slate-900">100+</p>
          <p>Ofertas activas en RM</p>
        </div>
        <div>
          <p class="text-xl font-bold text-slate-900">&lt;30s</p>
          <p>Para publicar un aviso</p>
        </div>
        <div>
          <p class="text-xl font-bold text-slate-900">RLS</p>
          <p>Privacidad de CVs garantizada</p>
        </div>
      </div>
    </div>
    <div class="card p-6 space-y-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs uppercase text-slate-500 font-semibold">Mapa en vivo</p>
          <p class="text-lg font-semibold text-slate-900">Ofertas georreferenciadas</p>
        </div>
        <span class="badge">Auto-refresh</span>
      </div>
      <div class="grid grid-cols-3 gap-3 text-sm">
        <div class="rounded-xl bg-brand-50 p-3">
          <p class="text-xs text-slate-600">Radio dinámico</p>
          <p class="text-lg font-bold text-brand-700">2 km</p>
        </div>
        <div class="rounded-xl bg-slate-50 p-3">
          <p class="text-xs text-slate-600">Tiempo carga</p>
          <p class="text-lg font-bold text-slate-900">1.2s</p>
        </div>
        <div class="rounded-xl bg-slate-900 text-white p-3">
          <p class="text-xs text-white/80">KPIs</p>
          <p class="text-lg font-bold">TTFP 42s</p>
        </div>
      </div>
      <div class="rounded-2xl bg-slate-900 text-white p-6 space-y-4">
        <p class="text-sm uppercase tracking-wide text-white/70">Modo empleador</p>
        <p class="text-xl font-semibold">Dashboard con métricas y CVs seguros</p>
        <p class="text-sm text-white/80">Control total de ofertas, métricas de conversión y descarga de postulaciones en un clic.</p>
        <Button href="/empleador/dashboard" variant="secondary">Abrir dashboard</Button>
      </div>
    </div>
  </div>
</section>
