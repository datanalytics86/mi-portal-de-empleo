---
import type { Oferta } from '../lib/ofertas';

interface Props {
  oferta: Oferta;
}

const { oferta } = Astro.props;
---

<a
  href={`/oferta/${oferta.id}`}
  data-oferta
  data-id={oferta.id}
  data-titulo={oferta.titulo}
  data-empresa={oferta.empresa}
  data-comuna={oferta.comuna}
  data-jornada={oferta.tipoJornada}
  class="block rounded-2xl border border-border/70 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-accent/40 hover:shadow-[0_16px_35px_rgba(15,23,42,0.08)]"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-lg font-semibold text-text-primary">{oferta.titulo}</h3>
      <p class="mt-1 text-sm text-text-secondary">{oferta.empresa}</p>
    </div>
    <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold text-accent">
      {oferta.tipoJornada}
    </span>
  </div>
  <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-text-secondary">
    <span>📍 {oferta.comuna}</span>
    <span>• {oferta.fecha}</span>
  </div>
  <p class="mt-4 text-sm text-text-secondary">{oferta.descripcion}</p>
</a>
