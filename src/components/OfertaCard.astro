---
import type { Oferta } from '@/lib/types/database';
import { formatRelativeTime } from '@/lib/utils/formatting';

interface Props {
  oferta: Oferta & { lat?: number; lng?: number };
}

const { oferta } = Astro.props;
---

<article
  class="card group transition-all"
  data-oferta-id={oferta.id}
  data-oferta-titulo={oferta.titulo}
  data-oferta-empresa={oferta.empresa}
  data-oferta-lat={oferta.lat || -33.4489}
  data-oferta-lng={oferta.lng || -70.6693}
>
  <div class="flex flex-col gap-3">
    <div class="flex items-start justify-between gap-4">
      <h3 class="text-xl font-semibold text-text-primary group-hover:text-accent transition-colors">
        <a href={`/oferta/${oferta.id}`} class="hover:underline">
          {oferta.titulo}
        </a>
      </h3>
      {
        oferta.activa ? (
          <span class="badge badge-green shrink-0">Activa</span>
        ) : (
          <span class="badge badge-red shrink-0">Cerrada</span>
        )
      }
    </div>

    <p class="text-text-secondary line-clamp-2">
      {oferta.descripcion}
    </p>

    <div class="flex flex-wrap items-center gap-4 text-sm text-text-secondary">
      <div class="flex items-center gap-1.5" title="Empresa">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
          ></path>
        </svg>
        <span>{oferta.empresa}</span>
      </div>

      <div class="flex items-center gap-1.5" title="Ubicación">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
          ></path>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <span>{oferta.comuna}</span>
      </div>

      <span class="badge badge-blue">
        {oferta.tipo_jornada}
      </span>

      {
        oferta.categoria && (
          <span class="badge badge-yellow">{oferta.categoria}</span>
        )
      }
    </div>

    <div class="flex items-center justify-between mt-2 pt-3 border-t border-border">
      <time
        datetime={oferta.created_at}
        class="text-xs text-text-secondary"
        title={new Date(oferta.created_at).toLocaleString('es-CL')}
      >
        Publicado {formatRelativeTime(oferta.created_at)}
      </time>

      <a
        href={`/oferta/${oferta.id}`}
        class="text-accent hover:text-accent-hover text-sm font-medium transition-colors inline-flex items-center gap-1"
        aria-label={`Ver detalles de ${oferta.titulo}`}
      >
        Ver detalles
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
