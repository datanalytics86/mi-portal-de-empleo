<form class="rounded-2xl border border-border/70 bg-white p-6 shadow-[0_12px_30px_rgba(15,23,42,0.06)]">
  <h2 class="text-lg font-semibold text-text-primary">Postula en segundos</h2>
  <p class="mt-2 text-sm text-text-secondary">Sin registro. Solo sube tu CV y listo.</p>

  <div class="mt-6 grid gap-4">
    <label class="text-sm text-text-secondary">
      Nombre (opcional)
      <input type="text" placeholder="Tu nombre" class="soft-input mt-2" />
    </label>
    <label class="text-sm text-text-secondary">
      Email (opcional)
      <input type="email" placeholder="tu@email.com" class="soft-input mt-2" />
    </label>
    <label class="text-sm text-text-secondary">
      CV (PDF o Word)
      <input
        type="file"
        accept=".pdf,.doc,.docx"
        required
        class="mt-2 w-full rounded-lg border border-dashed border-border bg-surface px-4 py-4 text-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/10"
      />
    </label>
  </div>

  <label class="mt-4 flex items-start gap-3 text-sm text-text-secondary">
    <input type="checkbox" required class="mt-1 h-4 w-4 rounded border-border/70 text-accent focus:ring-2 focus:ring-accent/10" />
    Acepto la política de privacidad
  </label>

  <button
    type="submit"
    class="mt-6 w-full rounded-lg bg-accent px-4 py-3 text-sm font-semibold text-white shadow-[0_12px_30px_rgba(66,153,225,0.35)] transition hover:-translate-y-0.5 hover:bg-accent-hover"
  >
    Enviar postulación
  </button>
</form>
