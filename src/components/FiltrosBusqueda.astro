---
import { comunasChile, categorias, tiposJornada } from '@/lib/comunas';

const { query = '', comuna = '', tipo_jornada = '', categoria = '' } = Astro.url.searchParams;
---

<div class="bg-white border border-border rounded-lg p-6 shadow-sm">
  <form
    method="GET"
    action="/"
    class="space-y-4"
    role="search"
    aria-label="Filtros de búsqueda de ofertas"
  >
    <!-- Búsqueda por texto -->
    <div>
      <label for="search-query" class="label">
        Buscar por título o empresa
      </label>
      <div class="relative">
        <input
          type="search"
          id="search-query"
          name="q"
          value={query}
          placeholder="Ej: Desarrollador, Vendedor..."
          class="input pl-10"
          autocomplete="off"
        />
        <svg
          class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-secondary pointer-events-none"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
    </div>

    <!-- Grid de filtros -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Filtro por comuna -->
      <div>
        <label for="filter-comuna" class="label">
          Comuna
        </label>
        <select
          id="filter-comuna"
          name="comuna"
          class="select"
        >
          <option value="">Todas las comunas</option>
          {
            comunasChile.map((c) => (
              <option value={c.nombre} selected={c.nombre === comuna}>
                {c.nombre}
              </option>
            ))
          }
        </select>
      </div>

      <!-- Filtro por tipo de jornada -->
      <div>
        <label for="filter-jornada" class="label">
          Tipo de jornada
        </label>
        <select
          id="filter-jornada"
          name="tipo_jornada"
          class="select"
        >
          <option value="">Todas</option>
          {
            tiposJornada.map((tipo) => (
              <option value={tipo} selected={tipo === tipo_jornada}>
                {tipo}
              </option>
            ))
          }
        </select>
      </div>

      <!-- Filtro por categoría -->
      <div>
        <label for="filter-categoria" class="label">
          Categoría
        </label>
        <select
          id="filter-categoria"
          name="categoria"
          class="select"
        >
          <option value="">Todas las categorías</option>
          {
            categorias.map((cat) => (
              <option value={cat} selected={cat === categoria}>
                {cat}
              </option>
            ))
          }
        </select>
      </div>
    </div>

    <!-- Botones -->
    <div class="flex flex-wrap items-center gap-3 pt-2">
      <button type="submit" class="btn btn-primary">
        <svg
          class="w-5 h-5 mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Buscar
      </button>

      <a
        href="/"
        class="btn btn-secondary"
        aria-label="Limpiar filtros"
      >
        <svg
          class="w-5 h-5 mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
          ></path>
        </svg>
        Limpiar
      </a>
    </div>
  </form>
</div>

<script>
  // Progressive enhancement: enviar formulario automáticamente al cambiar filtros
  const form = document.querySelector('form[role="search"]');
  if (form) {
    const selects = form.querySelectorAll('select');
    selects.forEach((select) => {
      select.addEventListener('change', () => {
        form.submit();
      });
    });
  }
</script>
