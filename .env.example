# Supabase Configuration
# Obtener de: https://app.supabase.com/project/_/settings/api
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (SOLO PARA SERVIDOR - NO EXPONER AL CLIENTE)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Site Configuration
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_SITE_NAME=Portal de Empleo Chile

# Upload Configuration
PUBLIC_MAX_CV_SIZE=5242880
PUBLIC_ALLOWED_FILE_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Rate Limiting
RATE_LIMIT_PER_IP_HOUR=3
RATE_LIMIT_PER_EMAIL_DAY=5
RATE_LIMIT_GLOBAL_MINUTE=100

# Security
# Generar con: openssl rand -base64 32
ENCRYPTION_KEY=your-32-char-encryption-key-here
HASH_SALT=your-hash-salt-here

# Environment
NODE_ENV=development

# Analytics (Opcional)
# PUBLIC_PLAUSIBLE_DOMAIN=tu-dominio.com
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Email (Para notificaciones - Fase 2)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASSWORD=tu-password
