# Supabase
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# xAI (SpaceXAI / Grok) — opcional pero recomendado para parsing de alta calidad
# https://console.x.ai
XAI_API_KEY=
XAI_MODEL=grok-3-mini

# Edge Function parse-cv (opcional) — reintentos async si el parse falla en Vercel
# SUPABASE_EDGE_PARSE_CV_URL=https://xxxxxxxxxxxx.supabase.co/functions/v1/parse-cv

# OCR para PDFs escaneados (sin capa de texto)
CV_OCR_ENABLED=true
CV_OCR_MAX_PAGES=3
CV_OCR_TIMEOUT_MS=50000
# Recomendado en Vercel: OCR.space (acepta PDF multipágina, sin binarios)
# Free key: https://ocr.space/ocrapi/freekey
OCR_SPACE_API_KEY=
