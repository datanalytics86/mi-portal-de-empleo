{
  "name": "mi-portal-de-empleo",
  "version": "0.1.0",
  "description": "Plataforma de empleos georeferenciada para Chile",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src --ext .ts,.tsx,.astro,.js,.jsx",
    "lint:fix": "eslint src --ext .ts,.tsx,.astro,.js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,js,jsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@astrojs/node": "^8.0.0",
    "@astrojs/tailwind": "^5.1.0",
    "@supabase/supabase-js": "^2.39.0",
    "astro": "^4.0.8",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "zod": "^3.22.4",
    "lucide-react": "^0.303.0",
    "isomorphic-dompurify": "^2.9.0",
    "file-type": "^18.7.0",
    "nanoid": "^5.0.4",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "@types/leaflet.markercluster": "^1.5.4",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "@astrojs/check": "^0.3.4",
    "eslint": "^8.56.0",
    "eslint-plugin-astro": "^0.31.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "prettier": "^3.1.1",
    "prettier-plugin-astro": "^0.12.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "@vitest/coverage-v8": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "empleos",
    "chile",
    "georeferenciacion",
    "leaflet",
    "astro",
    "supabase"
  ],
  "author": "",
  "license": "MIT"
}
